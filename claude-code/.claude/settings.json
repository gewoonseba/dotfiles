{
  "permissions": {
    "allow": [
      "mcp__pencil",
      "Skill(conversation-search)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(gh:*)",
      "Bash(npx:*)",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(lsof:*)",
      "Bash(env:*)",
      "Bash(curl:*)",
      "Bash(source:*)",
      "Bash(cc-conversation-search:*)",
      "Bash(uv:*)",
      "Bash(open:*)",
      "Bash(rm:*)",
      "Bash(chmod +x:*)",
      "Bash(jt:*)",
      "mcp__plugin_figma_figma__generate_figma_design",
      "mcp__plugin_figma_figma__use_figma",
      "mcp__plugin_figma_figma__whoami",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/claude-hook-lint-frontend.sh",
            "statusMessage": "Linting frontend..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); printf \"\\e[36m➜\\e[0m  \\e[1m%s\\e[0m \\e[32m%s\\e[0m\" \"$(basename \"$current_dir\")\" \"$model\""
  },
  "enabledPlugins": {
    "conversation-search@cc-conversation-search": true,
    "figma@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cc-conversation-search": {
      "source": {
        "source": "github",
        "repo": "akatz-ai/cc-conversation-search"
      }
    }
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true
}
