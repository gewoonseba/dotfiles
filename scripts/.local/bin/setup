#!/usr/bin/env bash
set -e

# Find the dotfiles root relative to this script's location
# Since it's in scripts/.local/bin/, root is 3 levels up
# Resolve symlinks to get the real script path
SCRIPT_PATH=$(readlink -f "$0")
DOTFILES_DIR=$(cd "$(dirname "$SCRIPT_PATH")/../../../" && pwd)
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
cd "$DOTFILES_DIR"

# True when running inside Windows Subsystem for Linux
is_wsl() {
    [ -n "${WSL_DISTRO_NAME:-}" ] || grep -qi microsoft /proc/version 2>/dev/null
}

echo "󰒓 Master Setup from $DOTFILES_DIR"

# --- Bootstrap: ensure baseline dependencies are installed ---
# Setup needs curl/stow/fzf to function. The stowed .zshrc also unguardedly
# sources fzf/starship/zoxide on shell startup, so we install those here too
# to avoid "command not found" errors on a fresh machine.
install_pkgs() {
    local pkgs=("$@")
    [ ${#pkgs[@]} -eq 0 ] && return 0

    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID}:${ID_LIKE:-}" in
            arch:*|*:*arch*|manjaro:*|endeavouros:*)
                if command -v yay &> /dev/null; then
                    yay -S --noconfirm --needed "${pkgs[@]}"
                else
                    sudo pacman -S --noconfirm --needed "${pkgs[@]}"
                fi
                ;;
            ubuntu:*|debian:*|pop:*|linuxmint:*|*:*debian*)
                sudo apt-get update
                sudo apt-get install -y "${pkgs[@]}"
                ;;
            *)
                echo "󰅙 Error: Unsupported Linux distribution: ${ID}"
                echo "  Install manually: ${pkgs[*]}"
                exit 1
                ;;
        esac
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        if ! command -v brew &> /dev/null; then
            echo "  Installing Homebrew..."
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi
        brew install "${pkgs[@]}"
    else
        echo "󰅙 Error: Unsupported OS: $OSTYPE"
        exit 1
    fi
}

bootstrap_deps() {
    # Baseline CLI tools — same package name across apt/brew/pacman.
    local pkg_missing=()
    for cmd in curl stow fzf jq zsh tmux eza; do
        command -v "$cmd" &> /dev/null || pkg_missing+=("$cmd")
    done
    # bat: Ubuntu ships the binary as `batcat` (.zshrc aliases it), so only
    # install the `bat` package if neither name is present.
    { command -v bat &> /dev/null || command -v batcat &> /dev/null; } || pkg_missing+=("bat")
    # WSL: wslu provides `wslview` so `open` can hand files/URLs to Windows.
    if is_wsl && ! command -v wslview &> /dev/null; then
        pkg_missing+=("wslu")
    fi
    if [ ${#pkg_missing[@]} -gt 0 ]; then
        echo "󰇚 Installing baseline packages: ${pkg_missing[*]}"
        install_pkgs "${pkg_missing[@]}"
    fi

    # Tools whose distro packaging is patchy — use their official installers.
    if ! command -v starship &> /dev/null; then
        echo "󰇚 Installing starship..."
        mkdir -p "$HOME/.local/bin"
        curl -sS https://starship.rs/install.sh | sh -s -- -y -b "$HOME/.local/bin"
    fi
    if ! command -v zoxide &> /dev/null; then
        echo "󰇚 Installing zoxide..."
        curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
    fi
}

# Make zsh the login shell — these dotfiles are zsh-centric.
ensure_login_shell_zsh() {
    local zsh_path
    zsh_path="$(command -v zsh)" || return 0

    local current="${SHELL:-}"
    if command -v getent &> /dev/null; then
        current="$(getent passwd "$USER" | awk -F: '{print $NF}')"
    fi
    case "$current" in
        */zsh) return 0 ;;  # already zsh
    esac

    echo "󰒓 zsh is installed but isn't your login shell ($current)."
    read -p "  Set zsh as your default shell? [Y/n] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        grep -qxF "$zsh_path" /etc/shells 2>/dev/null || echo "$zsh_path" | sudo tee -a /etc/shells > /dev/null
        if chsh -s "$zsh_path"; then
            echo "  󰄬 Default shell set to zsh (takes effect on next login)"
        else
            echo "  ⚠ chsh failed — set it manually: chsh -s $zsh_path"
        fi
    fi
}

# Raise sshd's per-connection channel limit. Tools like emdash multiplex many
# channels (shells + sftp) over a single SSH connection, one per parallel agent
# task, so the default MaxSessions of 10 is quickly exhausted ("SSH channel
# unavailable"). Idempotent: skips if an active MaxSessions line already exists.
ensure_ssh_maxsessions() {
    local conf=/etc/ssh/sshd_config
    local want=100
    [ -f "$conf" ] || return 0
    { command -v sshd &> /dev/null || [ -x /usr/sbin/sshd ]; } || return 0

    # Already set (uncommented) — leave whatever value is there.
    grep -qE '^[[:space:]]*MaxSessions[[:space:]]+' "$conf" && return 0

    echo "󰒓 sshd MaxSessions is unset (default 10) — too low for parallel-agent"
    echo "  tools like emdash that open many channels per SSH connection."
    read -p "  Set 'MaxSessions $want' in $conf? [Y/n] " -n 1 -r
    echo
    [[ $REPLY =~ ^[Nn]$ ]] && return 0

    echo "MaxSessions $want" | sudo tee -a "$conf" > /dev/null
    if sudo sshd -t; then
        sudo systemctl reload ssh 2>/dev/null \
            || sudo systemctl reload sshd 2>/dev/null \
            || echo "  ⚠ Set MaxSessions $want, but couldn't reload sshd — reload it manually"
        echo "  󰄬 MaxSessions set to $want"
    else
        echo "  ⚠ sshd config test failed — review $conf"
    fi
}

bootstrap_deps
ensure_login_shell_zsh
ensure_ssh_maxsessions

# Available tools — order here is the install order
# Format: "<script-name>|<description>"
TOOLS=(
    "rsync-install|rsync (file sync)"
    "node-install|Node.js + npm (via nvm)"
    "uv-install|uv (Python package manager)"
    "claude-install|Claude Code CLI"
    "zed-install|Zed editor"
    "git-worktree-runner-install|git-worktree-runner"
    "tod-install|tod (todo CLI)"
)

# Keep only tools whose script actually exists
AVAILABLE=()
for entry in "${TOOLS[@]}"; do
    script="${entry%%|*}"
    if [ -f "$SCRIPT_DIR/$script" ]; then
        AVAILABLE+=("$entry")
    fi
done

if [ ${#AVAILABLE[@]} -eq 0 ]; then
    echo "  No installable scripts found in $SCRIPT_DIR"
    exit 0
fi

# Show fzf multi-select.
# fzf --multi: Tab/Space toggles, Enter confirms, Esc cancels.
# Ctrl-A selects all.
mapfile -t SELECTED_SCRIPTS < <(
    printf '%s\n' "${AVAILABLE[@]}" \
        | awk -F'|' '{ printf "%-32s  %s\n", $1, $2 }' \
        | fzf --multi \
              --height=50% \
              --reverse \
              --no-info \
              --bind 'ctrl-a:select-all,ctrl-d:deselect-all' \
              --header=$'Space/Tab: toggle  ·  Ctrl-A: all  ·  Enter: install  ·  Esc: cancel\n' \
              --prompt='Tools ❯ ' \
        | awk '{print $1}'
)

if [ ${#SELECTED_SCRIPTS[@]} -eq 0 ]; then
    echo "  Nothing selected. Exiting."
    exit 0
fi

# Run in TOOLS order (not selection order), so dependencies stay correct
echo ""
echo "󰄬 Installing ${#SELECTED_SCRIPTS[@]} tool(s)..."
for entry in "${TOOLS[@]}"; do
    script="${entry%%|*}"
    for sel in "${SELECTED_SCRIPTS[@]}"; do
        if [ "$sel" = "$script" ]; then
            echo ""
            echo "── $script ──────────────────────────────"
            bash "$SCRIPT_DIR/$script"
            break
        fi
    done
done

# --- Global Stow ---
echo ""
echo "󰛢 Stowing configurations..."
# Ensure stow ignores macOS junk etc. Stow only reads .stow-global-ignore
# from $HOME, so symlink the repo's version there if it isn't already.
if [ ! -e "$HOME/.stow-global-ignore" ]; then
    ln -s "$DOTFILES_DIR/.stow-global-ignore" "$HOME/.stow-global-ignore"
    echo "  󰄬 Linked .stow-global-ignore → \$HOME"
fi

# Core, headless-safe configs stowed on every platform. Desktop-only folders
# (ghostty, hypr, cursor*, zed) can't run headless and are excluded on WSL —
# editing is done from the Windows host (e.g. Cursor/VS Code over Remote-WSL).
# Skills are handled separately by the agents-sync-skills step below.
STOW_FOLDERS="zsh tmux starship claude scripts"

# ~/.claude holds live runtime state (credentials, history). Stowing claude only
# folds in settings.json and leaves runtime files alone. Back up a pre-existing
# *real* settings.json so `stow claude` won't abort on a conflict.
if [ -f "$HOME/.claude/settings.json" ] && [ ! -L "$HOME/.claude/settings.json" ]; then
    echo "  Backing up existing ~/.claude/settings.json → settings.json.pre-stow.bak"
    mv "$HOME/.claude/settings.json" "$HOME/.claude/settings.json.pre-stow.bak"
fi

for folder in $STOW_FOLDERS; do
    if [ -d "$folder" ]; then
        stow -D "$folder" 2>/dev/null || true
        stow "$folder"
        echo "  󰄬 Stowed $folder"
    fi
done

# 'agents' has its own sync flow — it stows itself and then symlinks the
# resulting ~/.agents/skills into every agent's expected location.
if [ -d "agents" ]; then
    echo ""
    bash "$SCRIPT_DIR/agents-sync-skills"
fi

echo ""
echo "󰄬 System ready. If this is a first-time setup, log out and back in."
