#!/usr/bin/env bash
# Sync agents/.codex/skills/ to match agents/.claude/skills/.
# Each Claude skill gets a relative symlink in the Codex skills folder so both
# agents share a single canonical source.
set -e

SCRIPT_PATH=$(readlink -f "$0")
DOTFILES_DIR=$(cd "$(dirname "$SCRIPT_PATH")/../../../" && pwd)

CLAUDE_DIR="$DOTFILES_DIR/agents/.claude/skills"
CODEX_DIR="$DOTFILES_DIR/agents/.codex/skills"

if [ ! -d "$CLAUDE_DIR" ]; then
    echo "󰅙 $CLAUDE_DIR does not exist"
    exit 1
fi

mkdir -p "$CODEX_DIR"

added=0
removed=0

# Add missing symlinks
for skill in "$CLAUDE_DIR"/*/; do
    [ -d "$skill" ] || continue
    name=$(basename "$skill")
    link="$CODEX_DIR/$name"
    if [ ! -L "$link" ]; then
        ln -sf "../../.claude/skills/$name" "$link"
        echo "  󰄬 + $name"
        added=$((added + 1))
    fi
done

# Remove dangling symlinks
for link in "$CODEX_DIR"/*; do
    [ -L "$link" ] || continue
    name=$(basename "$link")
    if [ ! -d "$CLAUDE_DIR/$name" ]; then
        rm "$link"
        echo "  󰅖 - $name"
        removed=$((removed + 1))
    fi
done

echo ""
echo "󰄬 Done. Added: $added, removed: $removed."
