#!/usr/bin/env bash
set -e

# node-install - Install Node.js (and npm) via nvm
# Cross-platform: works on Linux and macOS.

echo "󰎙 Installing Node.js via nvm..."

export NVM_DIR="${XDG_DATA_HOME:-${HOME}/.local/share}/nvm"

# Install nvm if missing
if [ ! -s "$NVM_DIR/nvm.sh" ]; then
    echo "  󰇚 Installing nvm..."
    mkdir -p "$NVM_DIR"
    PROFILE=/dev/null curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
fi

# Source nvm into this shell
# shellcheck disable=SC1091
. "$NVM_DIR/nvm.sh"

# Install LTS node if no node version is active
if ! nvm current >/dev/null 2>&1 || [ "$(nvm current)" = "none" ] || [ "$(nvm current)" = "system" ]; then
    echo "  󰇚 Installing Node.js LTS..."
    nvm install --lts
    nvm alias default 'lts/*'
else
    echo "  󰄬 Node already active: $(nvm current)"
fi

nvm use default >/dev/null

# Configure npm-global prefix so `npm install -g` doesn't need sudo
# and lands in the path already exported from .zshrc
NPM_GLOBAL="$HOME/.npm-global"
mkdir -p "$NPM_GLOBAL"
npm config set prefix "$NPM_GLOBAL"

echo "  󰄬 node $(node --version) / npm $(npm --version)"
echo "󰄬 Node.js installed successfully"
