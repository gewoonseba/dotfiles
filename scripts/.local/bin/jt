#!/usr/bin/env bash
# Re-exec under bash 4+ if needed. macOS ships bash 3.2, which lacks associative
# arrays (declare -A); this script relies on them (e.g. _wt_collect's PR maps).
# Homebrew installs a modern bash at one of the paths below.
if [ -z "${BASH_VERSINFO:-}" ] || [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
    for _b in /opt/homebrew/bin/bash /usr/local/bin/bash; do
        [ -x "$_b" ] && exec "$_b" "$0" "$@"
    done
    echo "jt: requires bash 4+ (macOS ships 3.2). Install with: brew install bash" >&2
    exit 1
fi
set -euo pipefail

# jt — Jolteon worktree & service manager
# See: jt help

# Base work dir — tolerate Work/work casing across machines. macOS's filesystem
# is case-insensitive (so lowercase resolves a "Work" dir), and WSL/Linux here
# uses lowercase "work". Prefer lowercase; fall back to capital for any
# case-sensitive box that uses "Work".
WORK="$HOME/work"; [ -d "$WORK" ] || WORK="$HOME/Work"
REPO="$WORK/jolteon"
# All worktrees live flat under ~/work/worktrees/<repo>/<worktree-name>, with a
# slash-free worktree name (a branch's '/' becomes '-' — see wt_dir). Keeping
# them one level deep, not nested by branch prefix, means the on-disk name is
# always a single directory that mirrors the branch.
WORKTREES="$WORK/worktrees/jolteon"

# Prefer system-installed Python (e.g. Homebrew) over uv-managed downloads
export UV_PYTHON_PREFERENCE=system

# ─── Helpers ───────────────────────────────────────────────

hint_worktree() {
    echo ""
    echo "Hint: make sure you're in a Jolteon worktree (see 'jt worktree list')."
}

# Resolve the on-disk worktree directory for a branch. Worktree names are
# slash-free, so a branch like 'feat/foo' maps to '<WORKTREES>/feat-foo'.
wt_dir() {
    printf '%s/%s' "$WORKTREES" "${1//\//-}"
}

# Echo a usable current directory, or fail with guidance. A shell whose cwd was
# moved or removed out from under it (e.g. after a worktree was relocated or
# removed) keeps a stale $PWD that no longer exists, which otherwise turns into
# a confusing "getcwd"/"no pyproject.toml" cascade in the commands below.
cwd_or_die() {
    local d
    d="$(pwd -L 2>/dev/null || true)"
    if [ -z "$d" ] || [ ! -d "$d" ]; then
        echo "Error: the current directory is unavailable — it was likely moved or removed" >&2
        echo "(e.g. after a worktree was relocated). Re-enter it in a fresh shell:" >&2
        echo "  cd $WORKTREES/<name>" >&2
        echo "…or pass the target explicitly instead of relying on the current directory." >&2
        return 1
    fi
    printf '%s\n' "$d"
}

# Interactive one-of picker over lines read from stdin. Uses fzf when present,
# otherwise a numbered menu. Echoes the chosen raw line on stdout; the UI and
# prompts go to the tty/stderr so callers can capture the result via $(...).
# Returns non-zero if there's nothing to pick or the user aborts.
pick_line() {
    local prompt="${1:-pick> }" input
    input="$(cat)"
    [ -z "$input" ] && { echo "Nothing to pick." >&2; return 1; }

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "$input" | fzf --prompt="$prompt" --height=40% --reverse --with-nth=1.. --delimiter=$'\t'
        return
    fi

    # Numbered fallback. Menu to stderr; read from the tty (stdin is the pipe).
    local -a rows=(); local line i=1
    while IFS= read -r line; do
        printf "  %2d) %s\n" "$i" "${line//$'\t'/  }" >&2
        rows+=("$line"); i=$((i+1))
    done <<< "$input"
    local choice
    read -rp "$prompt[1-${#rows[@]}]: " choice </dev/tty || return 1
    [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#rows[@]}" ] \
        || { echo "Invalid choice." >&2; return 1; }
    printf '%s\n' "${rows[$((choice-1))]}"
}

# Emit "branch<TAB>dir" for each worktree with a checked-out branch. Pass
# "managed" to restrict to jt worktrees under $WORKTREES (skips the main
# checkout and other tools' trees). Detached worktrees have no branch and are
# omitted (nothing to key remove/nuke on).
worktrees_tsv() {
    local managed="${1:-}"
    git -C "$REPO" worktree list --porcelain 2>/dev/null | awk -v managed="$managed" -v wt="$WORKTREES/" '
        /^worktree / { d=substr($0, 10) }
        /^branch /   { b=$2; sub("refs/heads/", "", b);
                       if (managed == "" || substr(d, 1, length(wt)) == wt) printf "%s\t%s\n", b, d }
    '
}

trap 'hint_worktree' ERR

# Fast bits (~1s): env files + CLAUDE.md + .claude/.cursor/.vscode +
# .compound-engineering. These must exist before an AI agent starts so it
# sees the full worktree.
setup_worktree_fast() {
    local target_dir="$1"

    echo "Copying environment files..."
    (cd "$REPO" && find . \( -name node_modules -o -name .venv -o -name .git -o -name .data -o -name .emdash \) -prune -o -name '.env' -print) | while read -r envfile; do
        if [ -f "$REPO/$envfile" ]; then
            mkdir -p "$target_dir/$(dirname "$envfile")"
            cp "$REPO/$envfile" "$target_dir/$envfile"
        fi
    done

    if [ -f "$REPO/CLAUDE.md" ]; then
        cp "$REPO/CLAUDE.md" "$target_dir/CLAUDE.md"
        echo "  copied CLAUDE.md"
    fi

    # .compound-engineering is fully gitignored (machine-local CE config), so it
    # won't arrive in a worktree created from origin/main — copy it across like
    # .claude so CE behaves the same in every worktree.
    local d
    for d in .claude .cursor .vscode .compound-engineering; do
        if [ -d "$REPO/$d" ] && [ ! -d "$target_dir/$d" ]; then
            cp -r "$REPO/$d" "$target_dir/$d"
            echo "  copied $d/"
        fi
    done
}

# Slow bits (tens of seconds to minutes): backgrounded with output to a log.
setup_worktree_deps() {
    local target_dir="$1"

    echo "Installing Python dependencies..."
    (cd "$target_dir" && uv sync --quiet)

    echo "Installing frontend dependencies..."
    (cd "$target_dir/services/frontend" && npm i --silent 2>/dev/null)

    echo "Installing pre-commit hooks..."
    (cd "$target_dir" && uv run pre-commit install)
}

# Full setup (used by 'jt worktree setup' where the user wants blocking output).
setup_worktree() {
    setup_worktree_fast "$1"
    setup_worktree_deps "$1"
}

# Launch an agent, optionally seeding it with an initial prompt. claude and
# codex take the prompt as a positional arg; agy needs -i (--prompt-interactive).
exec_agent() {
    local agent="$1" prompt="${2:-}"
    if [ -z "$prompt" ]; then
        exec "$agent"
    fi
    case "$agent" in
        agy) exec "$agent" -i "$prompt" ;;
        *)   exec "$agent" "$prompt" ;;
    esac
}

# Locate the Zed binary — 'zed' on most installs, 'zeditor' on some Linux
# packages. Echoes the resolved path; returns non-zero if neither is present.
find_zed() {
    command -v zed 2>/dev/null || command -v zeditor 2>/dev/null
}

post_create_worktree() {
    local worktree_dir="$1"
    local preamble="${2:-}"
    local log_file="$worktree_dir/.jt-setup.log"

    # Fast bits synchronously so the agent sees CLAUDE.md / .claude/ on boot.
    setup_worktree_fast "$worktree_dir"

    # Slow bits in background, output to log.
    (setup_worktree_deps "$worktree_dir" >"$log_file" 2>&1) &
    disown 2>/dev/null || true

    # Always tell the wrapper where to cd, even if user aborts the prompt.
    if [ -n "${JT_CD_FILE:-}" ]; then
        printf '%s\n' "$worktree_dir" > "$JT_CD_FILE"
    fi

    echo ""
    echo "Worktree ready at: $worktree_dir"
    echo "Dependencies installing in background (log: $log_file)"
    echo ""
    echo "Open the worktree in?"
    echo "  1) claude"
    echo "  2) codex"
    echo "  3) agy"
    echo "  4) zed"
    echo "  5) none"
    read -rp "Choice [5]: " choice

    local agent="" open_zed=0
    case "${choice:-5}" in
        1|claude) agent="claude" ;;
        2|codex)  agent="codex" ;;
        3|agy)    agent="agy" ;;
        4|zed)    open_zed=1 ;;
    esac

    # Zed is a GUI editor that returns immediately, so launch it here (detached)
    # and let the cd still happen — you end up with the IDE open AND your shell in
    # the worktree. Agents, by contrast, take over the terminal via the wrapper.
    if [ "$open_zed" -eq 1 ]; then
        local zed_cmd
        if zed_cmd="$(find_zed)"; then
            ("$zed_cmd" "$worktree_dir" >/dev/null 2>&1 &)
            echo "Opening worktree in Zed..."
        else
            echo "zed/zeditor not found — skipping IDE launch."
        fi
    fi

    # Wrapper path: hand the agent (and any preamble) to the zsh function so it
    # runs in the user's real shell (after the cd). The wrapper handles the
    # "not found" case.
    if [ -n "${JT_AGENT_FILE:-}" ]; then
        if [ -n "$agent" ]; then
            printf '%s\n' "$agent" > "$JT_AGENT_FILE"
            [ -n "$preamble" ] && [ -n "${JT_PROMPT_FILE:-}" ] && printf '%s' "$preamble" > "$JT_PROMPT_FILE"
        fi
        exit 0
    fi

    # Fallback for when jt is invoked without the zsh wrapper: best-effort
    # cd + exec inside this process.
    cd "$worktree_dir"
    if [ -n "$agent" ]; then
        command -v "$agent" >/dev/null 2>&1 || { echo "$agent not found."; exit 0; }
        exec_agent "$agent" "$preamble"
    fi
    exit 0
}

# Parse --lcl/--dev/--prd flags into $ENV_CHOICE. Unknown args go to $REMAINING_ARGS.
parse_env_flag() {
    ENV_CHOICE=""
    PERSONA=""
    REMAINING_ARGS=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --lcl) ENV_CHOICE="lcl"; shift ;;
            --dev) ENV_CHOICE="dev"; shift ;;
            --prd) ENV_CHOICE="prd"; shift ;;
            --as)
                # --as <persona>; a bare --as (or one followed by another flag)
                # defaults to root.
                if [ -n "${2:-}" ] && [ "${2#--}" = "$2" ]; then
                    PERSONA="$2"; shift 2
                else
                    PERSONA="root"; shift
                fi
                ;;
            *)     REMAINING_ARGS+=("$1"); shift ;;
        esac
    done
}

prompt_env() {
    local default="$1"
    local default_num
    case "$default" in
        lcl) default_num=1 ;;
        dev) default_num=2 ;;
        prd) default_num=3 ;;
    esac
    echo "Select environment:" >&2
    echo "  1) lcl" >&2
    echo "  2) dev" >&2
    echo "  3) prd" >&2
    local choice
    read -rp "Environment [$default_num]: " choice
    case "${choice:-$default_num}" in
        1|lcl) echo "lcl" ;;
        2|dev) echo "dev" ;;
        3|prd) echo "prd" ;;
        *)     echo "Invalid choice" >&2; exit 1 ;;
    esac
}

# ─── Worktree commands ─────────────────────────────────────

cmd_worktree_create() {
    local branch="${1:-}"
    local preamble="${2:-}"
    [ -z "$branch" ] && { echo "Usage: jt worktree create <branch>"; exit 1; }
    local worktree_dir; worktree_dir="$(wt_dir "$branch")"

    if [ -d "$worktree_dir" ]; then
        echo "Error: directory already exists: $worktree_dir"
        echo "Use 'jt worktree open $branch' to cd into it, or 'jt worktree edit $branch' to open in Zed."
        exit 1
    fi

    echo "Creating worktree: $branch"
    git -C "$REPO" fetch origin main --quiet
    mkdir -p "$(dirname "$worktree_dir")"
    git -C "$REPO" worktree add -b "$branch" "$worktree_dir" origin/main
    git -C "$worktree_dir" push -u origin "$branch" --quiet

    post_create_worktree "$worktree_dir" "$preamble"
}

cmd_worktree_checkout() {
    local branch="${1:-}"
    local preamble="${2:-}"
    if [ -z "$branch" ]; then
        # Fuzzy-pick a remote branch that isn't already checked out somewhere.
        echo "Fetching remote branches..." >&2
        git -C "$REPO" fetch origin --prune --quiet
        local checked_out
        checked_out="$(git -C "$REPO" worktree list --porcelain | awk '/^branch /{sub("refs/heads/","",$2); print $2}')"
        branch="$(git -C "$REPO" for-each-ref --format='%(refname:short)' refs/remotes/origin \
            | sed 's#^origin/##' | grep -vxF HEAD \
            | grep -vxF "$checked_out" | sort -u \
            | pick_line "checkout> ")" || { echo "Aborted."; exit 0; }
    fi
    [ -z "$branch" ] && { echo "Usage: jt worktree checkout <branch>"; exit 1; }
    local worktree_dir; worktree_dir="$(wt_dir "$branch")"

    if [ -d "$worktree_dir" ]; then
        echo "Error: directory already exists: $worktree_dir"
        echo "Use 'jt worktree open $branch' to cd into it, or 'jt worktree edit $branch' to open in Zed."
        exit 1
    fi

    echo "Fetching remote branch: $branch"
    git -C "$REPO" fetch origin "$branch" --quiet

    if ! git -C "$REPO" rev-parse "origin/$branch" >/dev/null 2>&1; then
        echo "Error: remote branch 'origin/$branch' not found."
        echo "Use 'jt worktree create $branch' to create a new branch instead."
        exit 1
    fi

    echo "Creating worktree: $branch"
    mkdir -p "$(dirname "$worktree_dir")"
    git -C "$REPO" worktree add "$worktree_dir" "origin/$branch"
    git -C "$worktree_dir" checkout -b "$branch" 2>/dev/null || true

    post_create_worktree "$worktree_dir" "$preamble"
}

cmd_worktree_open() {
    local branch="${1:-}"
    local target_dir=""

    if [ -z "$branch" ]; then
        # Interactive picker over all worktrees (branch \t dir).
        local pick
        pick="$(worktrees_tsv | pick_line "worktree> ")" || { echo "Aborted."; exit 0; }
        target_dir="$(printf '%s' "$pick" | cut -f2)"
        [ -n "$target_dir" ] || { echo "No selection."; exit 1; }
    else
        target_dir="$(wt_dir "$branch")"
        if [ ! -d "$target_dir" ]; then
            echo "Error: no worktree at $target_dir"
            echo "Use 'jt worktree list' to see available worktrees, or 'jt worktree create $branch' to create one."
            exit 1
        fi
    fi

    if [ -n "${JT_CD_FILE:-}" ]; then
        printf '%s\n' "$target_dir" > "$JT_CD_FILE"
        exit 0
    fi

    cd "$target_dir"
    exec "$SHELL"
}

# ─── Worktree dashboard (shared helpers) ──────────────────────
#
# 'jt wt' opens an interactive fzf dashboard; 'jt wt list' prints the same
# data statically. Both share the collectors/renderers below so the two views
# never drift.

# _wt_trunc <str> <width> [end]   (end=1 -> keep tail / left ellipsis)
_wt_trunc() {
    local s="$1" w="$2" end="${3:-0}"
    (( ${#s} <= w )) && { printf '%s' "$s"; return; }
    if (( end )); then printf '…%s' "${s: -$((w - 1))}"; else printf '%s…' "${s:0:$((w - 1))}"; fi
}

# _wt_daylabel <epoch> <today-ymd> <yesterday-ymd>  ->  "Today  2026-07-13"
_wt_daylabel() {
    local act="$1" today="$2" yest="$3" day
    day=$(date -d "@$act" +%Y-%m-%d)
    case "$day" in
        "$today") printf 'Today      %s' "$day" ;;
        "$yest")  printf 'Yesterday  %s' "$day" ;;
        *)        printf '%s  %s' "$(date -d "@$act" +'%a %d %b')" "$day" ;;
    esac
}

# Emit one sorted TSV record per worktree, most-recent activity first:
#   act \t branch \t dir \t src \t prstate \t prnum \t prtitle \t subject
# Activity = max(last-commit time, folder mtime). PR fields come from a single
# 'gh pr list' call; subject is the last commit's subject (fallback summary).
_wt_collect() {
    declare -A pr_state pr_num pr_title
    if command -v gh >/dev/null 2>&1; then
        local ref st num title
        while IFS=$'\t' read -r ref st num title; do
            [ -z "$ref" ] && continue
            [ -n "${pr_state[$ref]:-}" ] && continue   # gh lists newest first; keep it
            pr_state[$ref]="$st"; pr_num[$ref]="$num"; pr_title[$ref]="$title"
        done < <( (cd "$REPO" && gh pr list --state all --limit 400 \
            --json number,title,headRefName,state,isDraft \
            --jq '.[] | [.headRefName, (if .isDraft then "DRAFT" else .state end), (.number|tostring), .title] | @tsv') 2>/dev/null )
    fi

    local rows="" branch dir logline ct subj mtime act src
    while IFS=$'\t' read -r branch dir; do
        [ -d "$dir" ] || continue
        logline=$(git -C "$dir" log -1 --format='%ct%x09%s' 2>/dev/null) || true
        ct=${logline%%$'\t'*}; subj=${logline#*$'\t'}
        [ "$subj" = "$logline" ] && subj=""            # no tab -> no commits
        [[ "$ct" =~ ^[0-9]+$ ]] || ct=0
        mtime=$(stat -c %Y "$dir" 2>/dev/null) || true; mtime=${mtime:-0}
        act=$ct; [ "$mtime" -gt "$act" ] && act=$mtime
        if   [ "$dir" = "$REPO" ];                     then src=main
        elif [[ "$dir" == "$WORKTREES"/* ]];           then src=jt
        elif [[ "$dir" == *"/.claude/worktrees/"* ]];  then src=claude
        elif [[ "$dir" == *"/emdash/"* || "$dir" == *"/.emdash/"* ]]; then src=emdash
        elif [[ "$dir" == *"/workspaces/"* ]];         then src=wksp
        else src=other
        fi
        rows+="$act"$'\t'"$branch"$'\t'"$dir"$'\t'"$src"$'\t'"${pr_state[$branch]:-}"$'\t'"${pr_num[$branch]:-}"$'\t'"${pr_title[$branch]:-}"$'\t'"$subj"$'\n'
    done < <(git -C "$REPO" worktree list --porcelain 2>/dev/null \
        | awk '/^worktree / { d=substr($0,10) } /^branch / { b=$2; sub("refs/heads/","",b); print b "\t" d }')

    [ -z "$rows" ] && return 0
    printf '%s' "$rows" | sort -t$'\t' -k1,1nr
}

# Render one dashboard row (no leading day header, no trailing newline).
#   _wt_render_row <color 0|1> <collect-record>
_wt_render_row() {
    local color="$1" rec="$2"
    local act branch dir src prstate prnum prtitle subj
    IFS=$'\t' read -r act branch dir src prstate prnum prtitle subj <<<"$rec"
    local reset dim bold green yellow purple red cyan blue grey
    if [ "$color" = 1 ]; then
        reset=$'\e[0m'; dim=$'\e[2m'; bold=$'\e[1m'
        green=$'\e[32m'; yellow=$'\e[33m'; purple=$'\e[35m'
        red=$'\e[31m'; cyan=$'\e[36m'; blue=$'\e[34m'; grey=$'\e[90m'
    else reset=; dim=; bold=; green=; yellow=; purple=; red=; cyan=; blue=; grey=; fi

    local dot statecol summary badge badgecol tm
    case "$prstate" in
        OPEN)   dot="${green}●${reset}";  statecol="$green" ;;
        DRAFT)  dot="${yellow}◐${reset}"; statecol="$yellow" ;;
        MERGED) dot="${purple}●${reset}"; statecol="$purple" ;;
        CLOSED) dot="${red}●${reset}";    statecol="$red" ;;
        *)      dot="${grey}○${reset}";   statecol="" ;;
    esac
    if [ -n "$prnum" ]; then
        summary="${statecol}#${prnum}${reset} $(_wt_trunc "$prtitle" 58)"
    else
        summary="${dim}$(_wt_trunc "${subj:-—}" 58)${reset}"
    fi
    case "$src" in
        main)   badgecol="$bold" ;;
        jt)     badgecol="$cyan" ;;
        emdash) badgecol="$purple" ;;
        claude) badgecol="$blue" ;;
        *)      badgecol="$grey" ;;
    esac
    badge=$(printf '%-8s' "[$src]")
    tm=$(date -d "@$act" +%H:%M)
    printf '  %s%s%s %s  %s%s%s  %s  %s' \
        "$dim" "$tm" "$reset" "$dot" \
        "$badgecol" "$badge" "$reset" \
        "$(printf '%-42s' "$(_wt_trunc "$branch" 42)")" \
        "$summary"
}

cmd_worktree_list() {
    # Static WIP dashboard: every worktree in day sections, newest first.
    local color=0; [ -t 1 ] && color=1
    local reset dim bold green yellow purple grey
    if [ "$color" = 1 ]; then
        reset=$'\e[0m'; dim=$'\e[2m'; bold=$'\e[1m'
        green=$'\e[32m'; yellow=$'\e[33m'; purple=$'\e[35m'; grey=$'\e[90m'
    else reset=; dim=; bold=; green=; yellow=; purple=; grey=; fi

    local data; data=$(_wt_collect)
    if [ -z "$data" ]; then echo "(no worktrees)"; return; fi

    local total open draft merged nopr
    total=$(printf '%s\n' "$data" | grep -c .) || true
    read -r open draft merged nopr < <(printf '%s\n' "$data" | awk -F'\t' '
        { if($5=="OPEN")o++; else if($5=="DRAFT")d++; else if($5=="MERGED")m++; else if($5=="")n++ }
        END { printf "%d %d %d %d\n", o+0, d+0, m+0, n+0 }') || true
    printf '%s%s worktrees%s  %s%s open%s · %s%s draft%s · %s%s merged%s · %s%s no-PR%s\n' \
        "$bold" "$total" "$reset" \
        "$green" "$open" "$reset" "$yellow" "$draft" "$reset" \
        "$purple" "$merged" "$reset" "$grey" "$nopr" "$reset"

    local today yesterday
    today=$(date +%Y-%m-%d)
    yesterday=$(date -d 'yesterday' +%Y-%m-%d 2>/dev/null) || yesterday=$(date -v-1d +%Y-%m-%d)

    local cur_day="" rec act day
    while IFS= read -r rec; do
        act=${rec%%$'\t'*}
        day=$(date -d "@$act" +%Y-%m-%d)
        if [ "$day" != "$cur_day" ]; then
            cur_day="$day"
            printf '\n%s%s%s\n' "$bold" "$(_wt_daylabel "$act" "$today" "$yesterday")" "$reset"
        fi
        printf '%s\n' "$(_wt_render_row "$color" "$rec")"
    done <<<"$data"

    printf '\n%s● open  ◐ draft  ● merged  ● closed  ○ no PR%s\n' "$dim" "$reset"
}

# Path to the dashboard feed cache. A fixed per-user path (not $$-based) so the
# fzf 'reload' subprocess (_fzffeed) and the parent UI process share one file:
# the UI builds the feed once, reuses it across the sessions drill-in round-trip
# so returning is instant, and 'Ctrl-X' remove rewrites it in place via _fzffeed.
_wt_feed_cache() {
    local d="${XDG_CACHE_HOME:-$HOME/.cache}/jt"
    mkdir -p "$d" 2>/dev/null || d="${TMPDIR:-/tmp}"
    printf '%s/wt-feed' "$d"
}

# Internal: feed lines for the fzf UI. Fields (TAB-separated):
#   1 visible(colored)  2 kind(row|header)  3 dir  4 branch  5 prstate  6 prnum  7 prtitle
_wt_fzf_feed() {
    local data; data=$(_wt_collect)
    [ -z "$data" ] && return 0
    local today yesterday
    today=$(date +%Y-%m-%d)
    yesterday=$(date -d 'yesterday' +%Y-%m-%d 2>/dev/null) || yesterday=$(date -v-1d +%Y-%m-%d)

    local bold=$'\e[1m' dim=$'\e[2m' reset=$'\e[0m'
    local cur_day="" act branch dir src prstate prnum prtitle subj day rec vis
    while IFS=$'\t' read -r act branch dir src prstate prnum prtitle subj; do
        day=$(date -d "@$act" +%Y-%m-%d)
        if [ "$day" != "$cur_day" ]; then
            cur_day="$day"
            printf '%s── %s ──%s\theader\t\t\t\t\t\n' \
                "$bold$dim" "$(_wt_daylabel "$act" "$today" "$yesterday")" "$reset"
        fi
        rec="$act"$'\t'"$branch"$'\t'"$dir"$'\t'"$src"$'\t'"$prstate"$'\t'"$prnum"$'\t'"$prtitle"$'\t'"$subj"
        vis=$(_wt_render_row 1 "$rec")
        printf '%s\trow\t%s\t%s\t%s\t%s\t%s\n' "$vis" "$dir" "$branch" "$prstate" "$prnum" "$prtitle"
    done <<<"$data"
}

# Internal: fzf preview pane.  _preview <dir> <prstate> <prnum> <prtitle>
cmd_worktree_preview() {
    local dir="${1:-}" prstate="${2:-}" prnum="${3:-}" prtitle="${4:-}"
    [ -n "$dir" ] && [ -d "$dir" ] || return 0
    local reset=$'\e[0m' dim=$'\e[2m' bold=$'\e[1m' cyan=$'\e[36m' yellow=$'\e[33m'
    local branch; branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null) || true
    printf '%s%s%s\n%s%s%s\n\n' "$bold" "${branch:-?}" "$reset" "$dim" "$dir" "$reset"
    if [ -n "$prnum" ]; then
        printf '%sPR #%s%s  (%s)\n%s\n\n' "$cyan" "$prnum" "$reset" "${prstate:-?}" "$prtitle"
    else
        printf '%sno PR%s\n\n' "$dim" "$reset"
    fi
    local dirty ab ahead behind
    dirty=$(git -C "$dir" status --porcelain 2>/dev/null | grep -c .) || true
    ab=$(git -C "$dir" rev-list --left-right --count origin/main...HEAD 2>/dev/null) || true
    behind=$(printf '%s' "$ab" | awk '{print $1+0}'); ahead=$(printf '%s' "$ab" | awk '{print $2+0}')
    printf '%s↑%s ahead  ↓%s behind  ·  %s file(s) dirty%s\n\n' \
        "$dim" "${ahead:-0}" "${behind:-0}" "${dirty:-0}" "$reset"
    printf '%s── recent commits ──%s\n' "$dim" "$reset"
    git -C "$dir" log -8 --color=always --format='%C(yellow)%h%Creset %s %C(dim)%cr%Creset' 2>/dev/null || true
}

# Internal: copy text to the clipboard (best-effort across platforms/WSL).
_wt_copy() {
    local text="$1" c
    for c in pbcopy wl-copy xclip; do
        command -v "$c" >/dev/null 2>&1 || continue
        case "$c" in
            xclip) printf '%s' "$text" | xclip -selection clipboard ;;
            *)     printf '%s' "$text" | "$c" ;;
        esac
        return
    done
    for c in clip.exe /mnt/c/Windows/System32/clip.exe; do
        if command -v "$c" >/dev/null 2>&1 || [ -x "$c" ]; then
            printf '%s' "$text" | "$c"; return
        fi
    done
    printf '%s\n' "$text"   # last resort: just print it
}

# Internal: open a branch's PR in the browser.
_wt_prweb() {
    local branch="$1" url
    url=$( (cd "$REPO" && gh pr view "$branch" --json url --jq .url) 2>/dev/null ) || true
    [ -z "$url" ] && { echo "No PR found for $branch"; return 0; }
    if   command -v wslview  >/dev/null 2>&1; then wslview "$url"
    elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$url"
    else echo "$url"; fi
}

# Internal: open a worktree in Zed (detached GUI). No-op if zed isn't found.
_wt_zed() {
    local dir="${1:-}" zed_cmd
    [ -d "$dir" ] || return 0
    zed_cmd="$(find_zed)" || return 0
    ("$zed_cmd" "$dir" >/dev/null 2>&1 &)
}

# Internal: remove one or more worktrees by their actual dirs (works for any
# source, not just jt-managed trees whose path is derivable from the branch).
# Called by the UI with the TAB-marked rows' dirs (or the highlighted row's dir
# when nothing is marked). Confirms once for the whole batch. The main checkout
# ($REPO) is never removed. Its branch is resolved per-dir and deleted too.
_wt_rm_multi() {
    local dirs=() d
    for d in "$@"; do
        [ -d "$d" ] || continue                     # skip blanks / day headers
        [ "$d" = "$REPO" ] && { echo "Skipping main checkout: $d"; continue; }
        dirs+=("$d")
    done
    [ "${#dirs[@]}" -eq 0 ] && { echo "Nothing to remove."; return 0; }

    echo "Remove ${#dirs[@]} worktree(s)?"
    for d in "${dirs[@]}"; do printf '  %s\n' "$d"; done
    local confirm
    read -rp "Proceed? [y/N] " confirm </dev/tty || return 0
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Kept."; return 0; }

    local branch
    for d in "${dirs[@]}"; do
        branch="$(git -C "$d" rev-parse --abbrev-ref HEAD 2>/dev/null)" || branch=""
        git -C "$REPO" worktree remove "$d" 2>/dev/null \
            || git -C "$REPO" worktree remove --force "$d"
        [ -n "$branch" ] && [ "$branch" != HEAD ] \
            && git -C "$REPO" branch -d "$branch" 2>/dev/null \
            && echo "Deleted branch: $branch" || true
        echo "Removed: $d"
    done
    read -rp "Press enter to continue… " _ </dev/tty 2>/dev/null || true
}

# New worktree from a blank branch, a GitHub issue, or a GitHub PR.
cmd_worktree_new() {
    echo "New worktree from:"
    echo "  1) blank branch"
    echo "  2) GitHub issue"
    echo "  3) GitHub PR"
    local kind; read -rp "Choice [1]: " kind </dev/tty || { echo "Aborted."; return 0; }
    case "${kind:-1}" in
        1|blank|b)
            local br; read -rp "Branch name: " br </dev/tty || { echo "Aborted."; return 0; }
            [ -z "$br" ] && { echo "Aborted."; return 0; }
            cmd_worktree_create "$br"
            ;;
        2|issue|i) cmd_issue_start ;;   # picks an issue, seeds an agent preamble
        3|pr|p)    cmd_pr_review ;;      # checks out the PR branch as a worktree
        *)         echo "Aborted." ;;
    esac
}

# Interactive fzf dashboard. Arrow keys to move; keys to act (see --header).
# Encode a directory to its Claude session-store folder name (Claude replaces
# both '/' and '.' with '-' when deriving the projects/<name> directory).
_wt_session_dir() {
    printf '%s/.claude/projects/%s' "$HOME" "$(printf '%s' "$1" | sed 's#[/.]#-#g')"
}

# Internal: fzf preview for a Claude session .jsonl — title + recent prompts.
cmd_session_preview() {
    local f="${1:-}"
    [ -f "$f" ] || return 0
    local reset=$'\e[0m' dim=$'\e[2m' bold=$'\e[1m' cyan=$'\e[36m'
    local title
    title=$(tac "$f" 2>/dev/null | grep -m1 -aE '"type": *"ai-title"' \
        | sed -E 's/.*"aiTitle": *"//; s/".*$//') || true
    printf '%s%s%s\n%s%s%s\n\n' "$bold" "${title:-(untitled)}" "$reset" \
        "$dim" "$(basename "$f" .jsonl)" "$reset"
    printf '%s── recent prompts ──%s\n' "$dim" "$reset"
    tac "$f" 2>/dev/null | grep -aE '"type": *"last-prompt"' \
        | sed -E 's/.*"lastPrompt": *"//; s/".*$//; s/\\n/ /g' \
        | awk '!seen[$0]++' | head -8 \
        | while IFS= read -r line; do
            printf '%s•%s %s\n' "$cyan" "$reset" "$(printf '%s' "$line" | cut -c1-72)"
          done
}

# Drill-in: pick a Claude session recorded in this worktree and resume it.
cmd_worktree_sessions() {
    local dir="${1:-}"
    [ -n "$dir" ] || return 0
    local self; self=$(command -v jt 2>/dev/null) || true
    [ -x "$self" ] || self="$0"

    local proj; proj="$(_wt_session_dir "$dir")"
    shopt -s nullglob
    local files=("$proj"/*.jsonl)
    shopt -u nullglob
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Claude sessions recorded in $dir"
        echo "(only sessions started at the worktree root are shown)"
        echo
        echo "Press enter to go back…"
        read -r _ </dev/tty 2>/dev/null || true
        return 0
    fi

    # Build feed: "visible(colored)\tid\tfile", newest first.
    local dim=$'\e[2m' reset=$'\e[0m' feed="" f id mt title tm
    feed=$(
        for f in "${files[@]}"; do
            id=$(basename "$f" .jsonl)
            mt=$(stat -c %Y "$f" 2>/dev/null) || true; mt=${mt:-0}
            title=$(tac "$f" 2>/dev/null | grep -m1 -aE '"type": *"ai-title"' \
                | sed -E 's/.*"aiTitle": *"//; s/".*$//') || true
            [ -z "$title" ] && title=$(tac "$f" 2>/dev/null | grep -m1 -aE '"type": *"last-prompt"' \
                | sed -E 's/.*"lastPrompt": *"//; s/".*$//; s/\\n/ /g') || true
            [ -z "$title" ] && title="(untitled)"
            printf '%s\t%s\t%s\t%s\n' "$mt" "$id" "$title" "$f"
        done | sort -t$'\t' -k1,1nr | while IFS=$'\t' read -r mt id title f; do
            tm=$(date -d "@$mt" +'%a %d %b %H:%M')
            printf '%s%s%s  %s  %s%s%s\trow\t%s\t%s\n' \
                "$dim" "$tm" "$reset" "$(_wt_trunc "$title" 60)" \
                "$dim" "${id:0:8}" "$reset" "$id" "$f"
        done
    )

    local out key sel id2
    out=$(printf '%s\n' "$feed" | fzf --ansi --delimiter=$'\t' --with-nth=1 \
        --reverse --height=100% --no-sort --no-multi \
        --header "sessions · $(basename "$dir")  ·  enter resume · ← back" \
        --preview "$self worktree _sesspreview {4}" \
        --preview-window 'right,50%,wrap,border-left' \
        --expect=enter,left) || true

    key=$(printf '%s\n' "$out" | sed -n 1p)
    sel=$(printf '%s\n' "$out" | sed -n 2p)
    if [ -z "$key" ] || [ "$key" = "left" ]; then return 0; fi   # esc / ← -> back
    id2=$(printf '%s' "$sel" | cut -f3)
    [ -n "$id2" ] || return 0

    command -v claude >/dev/null 2>&1 || { echo "claude not found in PATH."; return 0; }
    # Land back in the worktree after Claude exits (wrapper reads JT_CD_FILE).
    [ -n "${JT_CD_FILE:-}" ] && printf '%s\n' "$dir" > "$JT_CD_FILE"
    cd "$dir"
    exec claude --resume "$id2"
}

cmd_worktree_ui() {
    if ! command -v fzf >/dev/null 2>&1 || [ ! -t 1 ]; then
        cmd_worktree_list; return
    fi
    local self; self=$(command -v jt 2>/dev/null) || true
    [ -x "$self" ] || self="$0"

    # Build the (network-backed) feed once, then loop over the cached copy.
    # Drilling into sessions and coming back reuses this file — no rebuild — so
    # the redraw is instant. 'Ctrl-X' remove rewrites the file in place (its
    # +reload runs _fzffeed, which tees back into the cache), so a removed
    # worktree is gone on the next redraw without a full recompute here.
    local cache; cache="$(_wt_feed_cache)"
    _wt_fzf_feed > "$cache"

    # Verbs are Ctrl-chords (never collide with type-to-filter, unlike bare
    # letters, and don't emit stray chars like Alt does under WSL/Windows
    # terminals). Self-contained actions (zed/copy/PR/remove/refresh) run inside
    # fzf via execute*/reload; the ones that hand off the parent shell (cd,
    # claude, new) or open a sub-picker (sessions) exit via --expect. Tab marks
    # rows (--multi); Ctrl-X removes every marked row (or the highlighted one).
    local out key sel kind dir branch
    while :; do
        out=$(fzf --ansi --delimiter=$'\t' --with-nth=1 \
            --reverse --height=100% --no-sort --multi --marker='✓' \
            --header 'type to filter · ↑↓ move · TAB mark · ENTER cd · Ctrl-O claude · Ctrl-E zed
→ sessions · Ctrl-X remove · Ctrl-Y copy · Ctrl-P PR · Ctrl-T new · Ctrl-R refresh · ESC quit' \
            --preview "$self worktree _preview {3} {5} {6} {7}" \
            --preview-window 'right,46%,wrap,border-left' \
            --bind "ctrl-e:execute-silent($self worktree _zed {3})" \
            --bind "ctrl-y:execute-silent($self worktree _copy {3})" \
            --bind "ctrl-p:execute-silent($self worktree _prweb {4})" \
            --bind "ctrl-x:execute($self worktree _rmmulti {+3})+reload($self worktree _fzffeed)" \
            --bind "ctrl-r:reload($self worktree _fzffeed)" \
            --expect=enter,ctrl-o,ctrl-t,right < "$cache") || true

        key=$(printf '%s\n' "$out" | sed -n 1p)
        sel=$(printf '%s\n' "$out" | sed -n 2p)     # first marked row, else current
        [ -z "$key" ] && return 0                   # esc / ctrl-c

        if [ "$key" = "ctrl-t" ]; then cmd_worktree_new; return; fi

        kind=$(printf '%s' "$sel" | cut -f2)
        dir=$(printf '%s' "$sel" | cut -f3)
        branch=$(printf '%s' "$sel" | cut -f4)
        [ "$kind" = "row" ] || continue             # day header -> reopen (cached)

        case "$key" in
            right)                                  # drill into Claude sessions
                cmd_worktree_sessions "$dir"; continue ;;   # back -> reuse cache
            enter)                                  # cd the parent shell in
                if [ -n "${JT_CD_FILE:-}" ]; then printf '%s\n' "$dir" > "$JT_CD_FILE"; return; fi
                cd "$dir"; exec "$SHELL" ;;
            ctrl-o)                                 # cd + launch claude
                if [ -n "${JT_AGENT_FILE:-}" ]; then
                    [ -n "${JT_CD_FILE:-}" ] && printf '%s\n' "$dir" > "$JT_CD_FILE"
                    printf '%s\n' claude > "$JT_AGENT_FILE"
                    return
                fi
                cd "$dir"; exec_agent claude ;;
        esac
    done
}

cmd_worktree_remove() {
    local branch="${1:-}"
    if [ -z "$branch" ]; then
        local pick
        pick="$(worktrees_tsv managed | pick_line "remove> ")" || { echo "Aborted."; exit 0; }
        branch="$(printf '%s' "$pick" | cut -f1)"
    fi
    [ -z "$branch" ] && { echo "Usage: jt worktree remove <branch>"; exit 1; }
    local worktree_dir; worktree_dir="$(wt_dir "$branch")"

    if [ ! -d "$worktree_dir" ]; then
        echo "No worktree at $worktree_dir"
        exit 1
    fi

    read -rp "Remove worktree at $worktree_dir? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        git -C "$REPO" worktree remove "$worktree_dir"
        git -C "$REPO" branch -d "$branch" 2>/dev/null && echo "Deleted branch: $branch" || true
        echo "Removed worktree: $worktree_dir"
    fi
}

cmd_worktree_cleanup() {
    echo "Fetching origin --prune..."
    git -C "$REPO" fetch origin --prune --quiet

    local -a clean_branches=() clean_dirs=() clean_reasons=()

    while IFS=$'\t' read -r dir branch; do
        [ -z "$branch" ] && continue
        [ "$branch" = "main" ] && continue
        # Safety: only touch worktrees inside $WORKTREES
        [[ "$dir" == "$WORKTREES"/* ]] || continue

        local upstream reason=""
        upstream=$(git -C "$REPO" for-each-ref --format='%(upstream:short)' "refs/heads/$branch" 2>/dev/null || true)
        # Never sweep a worktree whose branch never had a remote branch (never pushed):
        # no upstream configured and no matching remote-tracking ref. These hold the only
        # copy of unpushed/uncommitted local work, so they must be removed deliberately
        # (jt worktree remove / nuke), never by the automatic cleanup.
        if [ -z "$upstream" ] && ! git -C "$REPO" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
            continue
        fi
        if [ -n "$upstream" ] && ! git -C "$REPO" show-ref --verify --quiet "refs/remotes/$upstream"; then
            reason="remote branch deleted"
        elif git -C "$REPO" merge-base --is-ancestor "$branch" origin/main 2>/dev/null; then
            reason="merged into main"
        else
            continue
        fi

        clean_branches+=("$branch")
        clean_dirs+=("$dir")
        clean_reasons+=("$reason")
    done < <(git -C "$REPO" worktree list --porcelain | awk '
        /^worktree / { d=substr($0, 10) }
        /^branch /   { b=$2; sub("refs/heads/", "", b); printf "%s\t%s\n", d, b }
    ')

    if [ ${#clean_branches[@]} -eq 0 ]; then
        echo "Nothing to clean up."
        git -C "$REPO" worktree prune
        return 0
    fi

    echo ""
    echo "Cleanable worktrees (${#clean_branches[@]}):"
    local i
    for i in "${!clean_branches[@]}"; do
        printf "  %-48s  (%s)\n" "${clean_branches[$i]}" "${clean_reasons[$i]}"
    done
    echo ""
    read -rp "Remove all ${#clean_branches[@]}? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; return 0; }

    for i in "${!clean_branches[@]}"; do
        local b="${clean_branches[$i]}" d="${clean_dirs[$i]}"
        if git -C "$REPO" worktree remove "$d" 2>/dev/null \
            || git -C "$REPO" worktree remove --force "$d" 2>/dev/null; then
            git -C "$REPO" branch -D "$b" >/dev/null 2>&1 || true
            echo "  removed $b"
        else
            echo "  ! failed to remove $b ($d)"
        fi
    done
    git -C "$REPO" worktree prune
    echo "Done."
}

cmd_worktree_nuke() {
    local branch="${1:-}"
    if [ -z "$branch" ]; then
        local pick
        pick="$(worktrees_tsv managed | pick_line "nuke> ")" || { echo "Aborted."; exit 0; }
        branch="$(printf '%s' "$pick" | cut -f1)"
    fi
    [ -z "$branch" ] && { echo "Usage: jt worktree nuke <branch>"; exit 1; }
    local worktree_dir; worktree_dir="$(wt_dir "$branch")"

    local has_worktree=0 has_local=0 has_remote=0
    [ -d "$worktree_dir" ] && has_worktree=1
    git -C "$REPO" show-ref --verify --quiet "refs/heads/$branch" && has_local=1
    git -C "$REPO" ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1 && has_remote=1

    if [ "$has_worktree" -eq 0 ] && [ "$has_local" -eq 0 ] && [ "$has_remote" -eq 0 ]; then
        echo "Nothing to nuke: no worktree, local branch, or remote branch for '$branch'."
        exit 1
    fi

    echo "About to NUKE '$branch':"
    [ "$has_worktree" -eq 1 ] && echo "  - worktree:      $worktree_dir (force, drops uncommitted changes)"
    [ "$has_local" -eq 1 ]    && echo "  - local branch:  $branch"
    [ "$has_remote" -eq 1 ]   && echo "  - remote branch: origin/$branch"

    read -rp "Continue? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }

    if [ "$has_worktree" -eq 1 ]; then
        git -C "$REPO" worktree remove --force "$worktree_dir" && echo "Removed worktree: $worktree_dir"
    fi
    if [ "$has_local" -eq 1 ]; then
        git -C "$REPO" branch -D "$branch" >/dev/null && echo "Deleted local branch: $branch"
    fi
    if [ "$has_remote" -eq 1 ]; then
        git -C "$REPO" push origin --delete "$branch" && echo "Deleted remote branch: origin/$branch"
    fi
    git -C "$REPO" worktree prune
}

cmd_worktree_setup() {
    local dir="${1:-}"
    [ -z "$dir" ] && { dir="$(cwd_or_die)" || exit 1; }

    if [ ! -d "$dir" ]; then
        # Try as a branch name
        if [ -d "$(wt_dir "$dir")" ]; then
            dir="$(wt_dir "$dir")"
        else
            echo "Error: no directory at $dir"
            exit 1
        fi
    fi

    setup_worktree "$dir"
    echo ""
    echo "Done. Worktree ready at:"
    echo "  $dir"
}

cmd_worktree_edit() {
    local branch="${1:-}"
    local dir

    if [ -z "$branch" ]; then
        dir="$(cwd_or_die)" || exit 1
    else
        dir="$(wt_dir "$branch")"
    fi

    if [ ! -d "$dir" ]; then
        echo "Error: no directory at $dir"
        exit 1
    fi

    local zed_cmd
    zed_cmd="$(find_zed)" || { echo "Error: zed/zeditor not found"; exit 1; }
    "$zed_cmd" "$dir"
}

# ─── Issue commands ────────────────────────────────────────

# Derive a branch name "<prefix>/<number>-<slug>" from an issue. Prefix comes
# from the GitHub issue type, falling back to a conventional title prefix
# (feat:/fix:/chore(scope):), else "feat".
issue_branch_name() {
    local number="$1" title="$2" itype="$3"
    local key="" prefix slug
    local conv_re='^([a-zA-Z]+)(\([^)]*\))?:'

    if [ -n "$itype" ]; then
        key="$itype"
    elif [[ "$title" =~ $conv_re ]]; then
        key="${BASH_REMATCH[1]}"
    fi

    case "$(printf '%s' "$key" | tr '[:upper:]' '[:lower:]')" in
        bug|fix)                                                  prefix="fix" ;;
        task|chore|"tech debt"|techdebt|docs|refactor|test|perf|ci|build|style) prefix="chore" ;;
        *)                                                        prefix="feat" ;;
    esac

    # Slug from the title: drop a leading conventional prefix, lowercase,
    # collapse non-alphanumerics to '-', trim, cap length.
    slug="$(printf '%s' "$title" \
        | sed -E 's/^[a-zA-Z]+(\([^)]*\))?:[[:space:]]*//' \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' \
        | cut -c1-50 | sed -E 's/-+$//')"
    [ -z "$slug" ] && slug="issue"

    printf '%s/%s-%s' "$prefix" "$number" "$slug"
}

cmd_issue_start() {
    local url="${1:-}"

    command -v gh >/dev/null 2>&1 || { echo "Error: gh (GitHub CLI) is required for 'jt issue'."; exit 1; }

    # No argument: fuzzy-pick from the repo's open issues.
    if [ -z "$url" ]; then
        echo "Fetching open issues from Companion-energy/jolteon..." >&2
        local pick
        pick="$(gh issue list --repo Companion-energy/jolteon --limit 100 --state open \
            --json number,title --jq '.[] | "#\(.number)\t\(.title)"' \
            | pick_line "issue> ")" || { echo "Aborted."; exit 0; }
        url="$(printf '%s' "$pick" | sed -E 's/^#([0-9]+).*/\1/')"
        [ -z "$url" ] && { echo "No selection."; exit 1; }
    fi

    # Accept a full issue URL or a bare number (defaults to the jolteon repo).
    local owner repo number
    if [[ "$url" =~ github\.com/([^/]+)/([^/]+)/issues/([0-9]+) ]]; then
        owner="${BASH_REMATCH[1]}"; repo="${BASH_REMATCH[2]}"; number="${BASH_REMATCH[3]}"
    elif [[ "$url" =~ ^[0-9]+$ ]]; then
        owner="Companion-energy"; repo="jolteon"; number="$url"
        url="https://github.com/$owner/$repo/issues/$number"
    else
        echo "Error: not a GitHub issue URL or number: $url"
        echo "Expected: https://github.com/<owner>/<repo>/issues/<number>"
        exit 1
    fi

    echo "Fetching issue #$number from $owner/$repo..."
    local meta title itype
    meta=$(gh api graphql -f query="{ repository(owner: \"$owner\", name: \"$repo\") { issue(number: $number) { title issueType { name } } } }" \
        --jq '.data.repository.issue | "\(.issueType.name // "")\t\(.title // "")"' 2>/dev/null) \
        || { echo "Error: could not fetch issue #$number from $owner/$repo (does it exist? are you authenticated with gh?)."; exit 1; }
    itype="${meta%%$'\t'*}"
    title="${meta#*$'\t'}"
    [ -z "$title" ] && { echo "Error: issue #$number has no title (not found?)."; exit 1; }

    local branch
    branch="$(issue_branch_name "$number" "$title" "$itype")"

    echo "Issue:   #$number  $title"
    echo "Branch:  $branch"

    local preamble
    preamble="You're starting work on GitHub issue #$number: \"$title\".
Issue: $url

Before making changes, fetch the issue for full context — e.g. \`gh issue view $url\` — then review the relevant code and propose an approach."

    cmd_worktree_create "$branch" "$preamble"
}

# ─── PR commands ───────────────────────────────────────────

cmd_pr_review() {
    local url="${1:-}"

    command -v gh >/dev/null 2>&1 || { echo "Error: gh (GitHub CLI) is required for 'jt pr'."; exit 1; }

    # No argument: fuzzy-pick from the repo's open PRs.
    if [ -z "$url" ]; then
        echo "Fetching open PRs from Companion-energy/jolteon..." >&2
        local pick
        pick="$(gh pr list --repo Companion-energy/jolteon --limit 100 \
            --json number,title,headRefName,author \
            --jq '.[] | "#\(.number)\t\(.title)\t\(.headRefName)\t@\(.author.login)"' \
            | pick_line "PR> ")" || { echo "Aborted."; exit 0; }
        url="$(printf '%s' "$pick" | sed -E 's/^#([0-9]+).*/\1/')"
        [ -z "$url" ] && { echo "No selection."; exit 1; }
    fi

    # Accept a full PR URL or a bare number (defaults to the jolteon repo).
    local owner repo number
    if [[ "$url" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
        owner="${BASH_REMATCH[1]}"; repo="${BASH_REMATCH[2]}"; number="${BASH_REMATCH[3]}"
    elif [[ "$url" =~ ^[0-9]+$ ]]; then
        owner="Companion-energy"; repo="jolteon"; number="$url"
        url="https://github.com/$owner/$repo/pull/$number"
    else
        echo "Error: not a GitHub PR URL or number: $url"
        echo "Expected: https://github.com/<owner>/<repo>/pull/<number>"
        exit 1
    fi

    echo "Fetching PR #$number from $owner/$repo..."
    local meta branch title
    meta=$(gh pr view "$number" --repo "$owner/$repo" --json headRefName,title \
        --jq '"\(.headRefName // "")\t\(.title // "")"' 2>/dev/null) \
        || { echo "Error: could not fetch PR #$number from $owner/$repo (does it exist? are you authenticated with gh?)."; exit 1; }
    branch="${meta%%$'\t'*}"
    title="${meta#*$'\t'}"
    [ -z "$branch" ] && { echo "Error: PR #$number has no head branch (cross-fork PRs aren't supported)."; exit 1; }

    echo "PR:      #$number  $title"
    echo "Branch:  $branch"

    # Invoke the /code-review skill directly — the worktree has the PR branch
    # checked out, so the skill reviews the PR's diff against main.
    local preamble="/code-review"

    cmd_worktree_checkout "$branch" "$preamble"
}

# ─── App commands ──────────────────────────────────────────

cmd_app_run() {
    parse_env_flag "$@"
    local env="$ENV_CHOICE"
    if [ ${#REMAINING_ARGS[@]} -gt 0 ]; then
        echo "Unknown argument: ${REMAINING_ARGS[0]}"
        echo "Usage: jt app run [--lcl|--dev|--prd] [--as <persona>]"
        exit 1
    fi

    if [ -z "$env" ]; then
        env="$(prompt_env lcl)"
    fi

    # Stop any running services first
    cmd_app_stop 2>/dev/null || true

    local env_file="$HOME/.config/jt/environments.sh"
    if [ ! -f "$env_file" ]; then
        echo "Error: missing $env_file"
        echo ""
        echo "Create it with env_lcl(), env_dev(), env_prd() shell functions."
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$env_file"

    case "$env" in
        lcl) env_lcl ;;
        dev) env_dev ;;
        prd) env_prd ;;
    esac

    # Persona override (auth bypass), layered on top of the env above so it wins
    # over whatever identity that env bundled. resolve_persona (in environments.sh)
    # errors on an undefined (env, persona) combo — abort rather than start as the
    # wrong / a non-existent user.
    if [ -n "${PERSONA:-}" ]; then
        resolve_persona "$env" "$PERSONA" || {
            echo "Aborting: persona '$PERSONA' is not defined for env '$env' in $env_file."
            exit 1
        }
    fi

    # Whenever the bypass is on (a persona, or env_prd), pin COMPANION_ENV=local so
    # the backend's DISABLE_AUTH gate activates and its startup assert is satisfied,
    # independent of which DB the env flag selected.
    if [ "${DISABLE_AUTH_RAW:-}" = "true" ]; then
        export COMPANION_ENV=local
    fi

    echo ""
    echo "Starting services..."
    echo "  Frontend: http://localhost:5173"
    echo "  Backend:  http://localhost:8000"
    echo ""
    echo "Viewing from another machine (e.g. your Mac)? Run 'jt app forward' there"
    echo "to tunnel these ports, then open the URLs above."
    echo ""

    # Disarm the trap before 'kill 0': that signals our own process group with
    # SIGTERM, and a still-armed TERM trap would re-run this handler, re-signal,
    # and loop — flooding the terminal with "Stopping services...".
    trap 'trap - INT TERM; echo ""; echo "Stopping services..."; kill 0' INT TERM

    (cd services/dashboard-api 2>/dev/null || cd "$REPO/services/dashboard-api"
     uv run uvicorn app.main:app --host 0.0.0.0 --port 8000) &

    local vite_env=""
    if [ "${DISABLE_AUTH_RAW:-}" = "true" ]; then
        # Pass both: VITE_DISABLE_AUTH activates the frontend bypass, and
        # VITE_COMPANION_ENV=local makes env.ts select localConfig explicitly
        # (the only config object carrying DISABLE_AUTH) instead of relying on
        # the unset-fallback. Setting only one of the pair causes a sign-out loop.
        vite_env="VITE_DISABLE_AUTH=true VITE_COMPANION_ENV=local"
    fi
    (cd services/frontend 2>/dev/null || cd "$REPO/services/frontend"
     env $vite_env npm run dev) &

    echo "Services started. Press Ctrl+C to stop."
    echo ""
    wait
}

cmd_app_stop() {
    local cur_pgid port pid pgid i pgids=""
    cur_pgid=$(ps -o pgid= -p $$ 2>/dev/null | tr -d ' ')

    # Collect the process GROUPS that own the dev ports, then kill whole groups —
    # not just the port-holding PIDs. 'jt app run' launches everything (uv-run +
    # uvicorn --reload + its worker + vite) in one process group, and the uvicorn
    # --reload supervisor does NOT itself hold the port. Killing only the port
    # holder leaves the supervisor alive to respawn its worker, so the port never
    # frees and the next 'jt app run' can't bind it (the "works on the 2nd try"
    # bug). Killing the group takes the supervisor down too. Skip our own group so
    # we never kill the in-progress 'jt app run' that called this.
    for port in 8000 5173; do
        for pid in $(lsof -ti :"$port" 2>/dev/null); do
            pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')
            [ -n "$pgid" ] && [ "$pgid" != "$cur_pgid" ] && pgids="$pgids $pgid"
        done
    done
    pgids=$(printf '%s\n' $pgids | sort -u)

    if [ -z "$pgids" ]; then
        echo "No services running."
        return 0
    fi

    for pgid in $pgids; do
        kill -9 -"$pgid" 2>/dev/null || true
    done
    echo "Stopped services (backend + frontend)"

    # Wait for the kernel to actually release the ports before returning, so the
    # following 'jt app run' binds cleanly.
    for port in 8000 5173; do
        for i in $(seq 1 50); do
            lsof -ti :"$port" >/dev/null 2>&1 || break
            sleep 0.1
        done
    done
}

# Open an SSH tunnel that forwards the app's dev ports from the remote box to
# this machine, so servers started with 'jt app run' over there are reachable
# at localhost here. Run this on your local machine (e.g. your Mac). Relies on a
# 'Host wsl' entry in ~/.ssh/config for the connection (host, port, user, key).
cmd_app_forward() {
    local host="devbox"
    local -a ports=(3000 5173 8000 8002)

    # SSH can't bind a local port that's already taken; warn before connecting.
    local -a busy=()
    local p
    for p in "${ports[@]}"; do
        lsof -ti :"$p" >/dev/null 2>&1 && busy+=("$p")
    done
    if [ ${#busy[@]} -gt 0 ]; then
        echo "Local ports already in use: ${busy[*]}"
        echo "If the app is running locally, stop it first ('jt app stop') so the"
        echo "box can serve it instead — otherwise those forwards will fail to bind."
        echo ""
    fi

    local -a fwd=()
    for p in "${ports[@]}"; do
        fwd+=(-L "$p:localhost:$p")
    done

    echo "Forwarding ${ports[*]} from '$host' -> localhost. Leave running (Ctrl+C to stop)."
    echo "Then open http://localhost:5173"
    echo ""
    exec ssh -N "${fwd[@]}" "$host"
}

# Serve a directory (default: the worktree's root .context folder — plans, docs,
# agent-generated HTML) over HTTP, bound to all interfaces so it's reachable from
# another machine on the tailnet (e.g. open http://pc-seba-1:8090/ on your Mac).
# Static files only, so no SSH tunnel is needed. Pass a dir and/or --port to override.
cmd_docs_serve() {
    local port="8090" dir=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --port) port="${2:-}"; [ -z "$port" ] && { echo "--port needs a value"; exit 1; }; shift 2 ;;
            *)      dir="$1"; shift ;;
        esac
    done

    if [ -z "$dir" ]; then
        local root
        root="$(git rev-parse --show-toplevel 2>/dev/null)" \
            || { echo "Not in a git worktree — pass a directory: jt docs serve <dir>"; exit 1; }
        dir="$root/.context"
    fi
    [ -d "$dir" ] || { echo "Nothing to serve: $dir does not exist"; exit 1; }

    # Free the port so re-running 'jt serve' just works.
    local pids
    pids=$(lsof -ti :"$port" 2>/dev/null || true)
    if [ -n "$pids" ]; then
        echo "$pids" | xargs kill -9 2>/dev/null || true
        sleep 0.3
    fi

    echo "Serving $dir at:"
    echo "  http://pc-seba-1:$port/   <- open this on your Mac (over Tailscale)"
    echo "  http://localhost:$port/   (on this box)"
    echo "Ctrl+C to stop."
    echo ""
    exec python3 -m http.server "$port" --bind 0.0.0.0 --directory "$dir"
}

# ─── Pulse commands ────────────────────────────────────────

# Allow the locally-run frontend to fetch pulse-report blobs from the dev
# Storage account in the browser.
#
# Why this is needed: dashboard-api hands the UI a *SAS URL* pointing straight
# at https://<account>.blob.core.windows.net/..., and the browser fetches it
# directly. That cross-origin request is blocked unless the Storage account
# carries a CORS rule for the frontend's origin — so a valid SAS URL still
# renders as an empty/broken report locally until this runs.
#
# Idempotent + self-contained: skips when a rule already allows the origin, and
# reuses COMPANION_STORAGE_CONNECTION_STRING from services/dashboard-api/.env
# (the same secret the backend authenticates with — mirrors how 'jt mcp run'
# sources dashboard-api creds), so no separate 'az login' is required.
cmd_pulse_cors() {
    local origin="${1:-http://localhost:5173}"

    command -v az >/dev/null 2>&1 || {
        echo "Error: the Azure CLI ('az') is required for 'jt pulse cors'."
        exit 1
    }

    # Prefer the current worktree's .env, fall back to the main checkout.
    local dashboard_env
    dashboard_env="$(cd services/dashboard-api 2>/dev/null && pwd)/.env" \
        || dashboard_env="$REPO/services/dashboard-api/.env"
    if [ ! -f "$dashboard_env" ]; then
        echo "Error: $dashboard_env not found — can't read the storage connection string."
        echo "Run this from a Jolteon worktree (or 'jt worktree setup' first)."
        exit 1
    fi

    # Read the raw value directly rather than sourcing: dotenv values are
    # unquoted, and a connection string is full of ';' — which the shell would
    # treat as command separators, truncating it at the first field.
    local conn
    conn="$(sed -nE 's/^[[:space:]]*COMPANION_STORAGE_CONNECTION_STRING=(.*)$/\1/p' "$dashboard_env" | head -1)"
    conn="${conn%\"}"; conn="${conn#\"}"   # strip optional surrounding quotes
    conn="${conn%\'}"; conn="${conn#\'}"
    if [ -z "$conn" ]; then
        echo "Error: COMPANION_STORAGE_CONNECTION_STRING is not set in $dashboard_env."
        exit 1
    fi

    local account
    account="$(printf '%s' "$conn" | sed -E 's/.*AccountName=([^;]*).*/\1/')"

    if az storage cors list --services b --connection-string "$conn" -o json 2>/dev/null \
        | grep -qF "$origin"; then
        echo "CORS already allows $origin on blob account '$account'. Nothing to do."
        echo "Run 'jt app run --dev', then open a pulse report in the UI."
        exit 0
    fi

    echo "Adding blob CORS rule on '$account': allow GET/HEAD from $origin ..."
    az storage cors add \
        --services b \
        --methods GET HEAD \
        --origins "$origin" \
        --allowed-headers '*' \
        --exposed-headers '*' \
        --max-age 3600 \
        --connection-string "$conn"

    echo ""
    echo "Done. The locally-run UI can now fetch pulse-report blobs from '$account'."
    echo "Next: 'jt app run --dev', then open a pulse report in the app."
}

# ─── MCP commands ──────────────────────────────────────────

cmd_mcp_run() {
    local env="" port="8002"
    while [ $# -gt 0 ]; do
        case "$1" in
            --lcl)  env="lcl"; shift ;;
            --dev)  env="dev"; shift ;;
            --prd)  env="prd"; shift ;;
            --port) port="${2:-}"; [ -z "$port" ] && { echo "--port needs a value"; exit 1; }; shift 2 ;;
            *)      echo "Unknown argument: $1"; echo "Usage: jt mcp run [--lcl|--dev|--prd] [--port N]"; exit 1 ;;
        esac
    done

    if [ -z "$env" ]; then
        env="$(prompt_env dev)"
    fi

    local mcp_dir
    mcp_dir="$(cd services/mcp-service 2>/dev/null && pwd)" || mcp_dir="$REPO/services/mcp-service"
    local spec_file="$mcp_dir/app/openapi_spec.json"

    # Generate OpenAPI spec if missing
    if [ ! -f "$spec_file" ]; then
        echo "OpenAPI spec not found, generating..."
        local api_dir
        api_dir="$(cd services/dashboard-api 2>/dev/null && pwd)" || api_dir="$REPO/services/dashboard-api"

        # Source env config for DB creds (needed by dashboard-api import)
        local env_file="$HOME/.config/jt/environments.sh"
        if [ -f "$env_file" ]; then
            # shellcheck source=/dev/null
            source "$env_file"
            env_dev  # dev creds are fine for spec generation
        fi

        (cd "$api_dir" && \
            GOOGLE_GEOCODING_API_KEY="${GOOGLE_GEOCODING_API_KEY:-x}" \
            WORKOS_CLIENT_ID="${WORKOS_CLIENT_ID:-x}" \
            WORKOS_CLIENT_SECRET="${WORKOS_CLIENT_SECRET:-x}" \
            FLUVIUS_CLIENT_SECRET="${FLUVIUS_CLIENT_SECRET:-x}" \
            FLUVIUS_SUBSCRIPTION_KEY="${FLUVIUS_SUBSCRIPTION_KEY:-x}" \
            DAGSTER_URL="${DAGSTER_URL:-http://x}" \
            PYTHONPATH=. uv run python ../mcp-service/scripts/generate_openapi_spec.py)
    fi

    # Stop any existing MCP server on this port
    local mcp_pids
    mcp_pids=$(lsof -ti :"$port" 2>/dev/null || true)
    if [ -n "$mcp_pids" ]; then
        echo "$mcp_pids" | xargs kill -9 2>/dev/null || true
        sleep 1
    fi

    # Set environment-specific config
    local dashboard_url disable_auth
    case "$env" in
        lcl)
            dashboard_url="http://localhost:8000"
            disable_auth="true"
            ;;
        dev)
            dashboard_url="https://dashboard-api.dev.companion.energy"
            disable_auth="false"
            ;;
        prd)
            dashboard_url="https://dashboard-api.prd.companion.energy"
            disable_auth="false"
            ;;
    esac

    # Source dashboard-api .env for WorkOS creds
    local dashboard_env
    dashboard_env="$(cd services/dashboard-api 2>/dev/null && pwd)/.env" || dashboard_env="$REPO/services/dashboard-api/.env"
    if [ -f "$dashboard_env" ]; then
        set -a
        # shellcheck source=/dev/null
        source "$dashboard_env"
        set +a
    fi

    echo ""
    echo "Starting MCP service..."
    echo "  Environment:    $env"
    echo "  Dashboard API:  $dashboard_url"
    echo "  Auth:           $([ "$disable_auth" = "true" ] && echo "disabled" || echo "OAuth (WorkOS)")"
    echo "  MCP endpoint:   http://localhost:$port/mcp/"
    echo ""

    trap 'echo ""; echo "Stopping MCP service..."; kill 0' INT TERM

    (cd "$mcp_dir" && \
        DASHBOARD_API_BASE_URL="$dashboard_url" \
        DISABLE_AUTH="$disable_auth" \
        MCP_BASE_URL="http://localhost:$port" \
        COMPANION_ENV="local" \
        LOG_LEVEL="INFO" \
        uv run uvicorn app.main:app --port "$port") &

    wait
}

cmd_mcp_stop() {
    local port="8002"
    while [ $# -gt 0 ]; do
        case "$1" in
            --port) port="${2:-}"; [ -z "$port" ] && { echo "--port needs a value"; exit 1; }; shift 2 ;;
            *)      echo "Unknown argument: $1"; echo "Usage: jt mcp stop [--port N]"; exit 1 ;;
        esac
    done

    local pids
    pids=$(lsof -ti :"$port" 2>/dev/null || true)
    if [ -n "$pids" ]; then
        echo "$pids" | xargs kill -9 2>/dev/null || true
        echo "Stopped MCP service (port $port)"
    else
        echo "No MCP service running on port $port."
    fi
}

# ─── Browser commands ──────────────────────────────────────

cmd_browser_open() {
    local profile="${1:-}"
    local url="${2:-http://localhost:5173}"
    local profiles_dir="$WORK/browser-profiles"

    if [ -z "$profile" ]; then
        # No profile: fuzzy-pick one of the available browser profiles.
        local names
        names="$(for p in "$profiles_dir"/*/; do [ -d "$p" ] && basename "$p"; done)"
        [ -z "$names" ] && { echo "No browser profiles in $profiles_dir"; exit 1; }
        profile="$(printf '%s\n' "$names" | pick_line "profile> ")" || { echo "Aborted."; exit 0; }
        [ -z "$profile" ] && { echo "No selection."; exit 1; }
    fi

    if [ ! -d "$profiles_dir/$profile" ]; then
        echo "Error: unknown profile '$profile'"
        echo "Available profiles:"
        for p in "$profiles_dir"/*/; do
            echo "  $(basename "$p")"
        done
        exit 1
    fi

    agent-browser close 2>/dev/null || true
    echo "Opening browser: $url (profile: $profile)"
    agent-browser --profile "$profiles_dir/$profile" --headed open "$url"
}

cmd_browser_stop() {
    if pkill -f 'agent-browser' 2>/dev/null; then
        echo "Stopped agent-browser"
    else
        echo "No agent-browser running."
    fi
}

# ─── Diff commands ─────────────────────────────────────────

cmd_diff_open() {
    local base=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -b|--base) base="${2:-}"; [ -z "$base" ] && { echo "--base needs a value"; exit 1; }; shift 2 ;;
            *)         echo "Unknown argument: $1"; echo "Usage: jt diff open [--base <branch>]"; exit 1 ;;
        esac
    done

    local -a args=(diffhub cmux)
    [ -n "$base" ] && args+=(--base "$base")
    exec npx "${args[@]}"
}

cmd_diff_stop() {
    if pkill -f 'diffhub' 2>/dev/null; then
        echo "Stopped diffhub"
    else
        echo "No diffhub process running."
    fi
}

# ─── SDK commands ──────────────────────────────────────────

cmd_sdk_generate() {
    local javm_bin
    javm_bin="$(command -v javm 2>/dev/null || echo "$HOME/.local/bin/javm")"
    if [ ! -x "$javm_bin" ]; then
        echo "Error: javm is not installed."
        echo ""
        echo "javm is required to manage Java versions for the OpenAPI generator."
        echo "Install it first, then re-run 'jt sdk generate'."
        exit 1
    fi

    if ! curl -sf http://localhost:8000/docs >/dev/null 2>&1; then
        echo "Dashboard API is not running on localhost:8000."
        read -rp "Start it with 'jt app run'? [Y/n] " confirm
        if [[ "${confirm:-y}" =~ ^[Nn]$ ]]; then
            echo "Aborted. Start the API first, then re-run 'jt sdk generate'."
            exit 1
        fi
        cmd_app_run
        # app run blocks (wait), so we won't reach here
    fi

    local sdk_dir
    sdk_dir="$(cd packages/dashboard-api-ts-sdk 2>/dev/null && pwd)" || sdk_dir="$REPO/packages/dashboard-api-ts-sdk"

    # javm modifies JAVA_HOME/PATH via a shell function (fd3 protocol) that is
    # only available in interactive zsh. Replicate the protocol directly so the
    # env vars are exported for npm run build.
    local fd3
    fd3=$(mktemp)
    "$javm_bin" --fd3 "$fd3" use 25
    if [ -s "$fd3" ]; then
        while IFS=$'\t' read -r op key val; do
            [ "$op" = "SET" ] && export "$key=$val"
            [ "$op" = "UNSET" ] && unset "$key"
        done < "$fd3"
    fi
    rm -f "$fd3"

    echo "Generating SDK..."
    (cd "$sdk_dir" && npm run build)
    echo "Done."
}

