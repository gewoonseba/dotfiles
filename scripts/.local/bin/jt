# ─── Main ──────────────────────────────────────────────────

dispatch_worktree() {
    local verb="${1:-ui}"        # bare 'jt wt' -> interactive dashboard
    shift 2>/dev/null || true
    case "$verb" in
        ui|i)        cmd_worktree_ui ;;
        create)      cmd_worktree_create "${1:-}" ;;
        checkout|co) cmd_worktree_checkout "${1:-}" ;;
        new)         cmd_worktree_new ;;
        list|ls)     cmd_worktree_list ;;
        open)        cmd_worktree_open "${1:-}" ;;
        edit)        cmd_worktree_edit "${1:-}" ;;
        setup)       cmd_worktree_setup "${1:-}" ;;
        remove|rm)   cmd_worktree_remove "${1:-}" ;;
        cleanup)     cmd_worktree_cleanup ;;
        nuke)        cmd_worktree_nuke "${1:-}" ;;
        # Internal verbs used by the fzf UI (preview / actions / reload feed).
        _preview)    cmd_worktree_preview "$@" ;;
        _sesspreview) cmd_session_preview "${1:-}" ;;
        _fzffeed)    _wt_fzf_feed | tee "$(_wt_feed_cache)" ;;
        _copy)       _wt_copy "${1:-}" ;;
        _prweb)      _wt_prweb "${1:-}" ;;
        _zed)        _wt_zed "${1:-}" ;;
        _rmmulti)    _wt_rm_multi "$@" ;;
        *)           echo "Unknown worktree verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_app() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        run)                cmd_app_run "$@" ;;
        stop)               cmd_app_stop ;;
        forward|fwd|tunnel) cmd_app_forward ;;
        *)    echo "Unknown app verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_mcp() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        run)  cmd_mcp_run "$@" ;;
        stop) cmd_mcp_stop "$@" ;;
        *)    echo "Unknown mcp verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_pulse() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        cors) cmd_pulse_cors "${1:-}" ;;
        *)    echo "Unknown pulse verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_browser() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        open) cmd_browser_open "${1:-}" "${2:-}" ;;
        stop) cmd_browser_stop ;;
        *)    echo "Unknown browser verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_sdk() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        generate|gen) cmd_sdk_generate ;;
        *)            echo "Unknown sdk verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_issue() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        start) cmd_issue_start "${1:-}" ;;
        *)     echo "Unknown issue verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_pr() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        review) cmd_pr_review "${1:-}" ;;
        *)      echo "Unknown pr verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_diff() {
    local verb="${1:-open}"
    shift 2>/dev/null || true
    case "$verb" in
        open) cmd_diff_open "$@" ;;
        stop) cmd_diff_stop ;;
        *)    echo "Unknown diff verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

dispatch_docs() {
    local verb="${1:-}"
    shift 2>/dev/null || true
    case "$verb" in
        serve) cmd_docs_serve "$@" ;;
        *)     echo "Unknown docs verb: $verb"; echo "Run 'jt help' for usage."; exit 1 ;;
    esac
}

noun="${1:-help}"
shift 2>/dev/null || true
case "$noun" in
    worktree|wt)    dispatch_worktree "$@" ;;
    app)            dispatch_app "$@" ;;
    mcp)            dispatch_mcp "$@" ;;
    pulse)          dispatch_pulse "$@" ;;
    browser)        dispatch_browser "$@" ;;
    sdk)            dispatch_sdk "$@" ;;
    diff)           dispatch_diff "$@" ;;
    issue)          dispatch_issue "$@" ;;
    pr)             dispatch_pr "$@" ;;
    setup)          cmd_worktree_setup "${1:-}" ;;
    # Top-level shortcuts for the most-used worktree verbs (like 'setup'). All
    # accept no arg and fall back to a fuzzy picker.
    open)           cmd_worktree_open "${1:-}" ;;
    remove|rm)      cmd_worktree_remove "${1:-}" ;;
    nuke)           cmd_worktree_nuke "${1:-}" ;;
    docs)           dispatch_docs "$@" ;;
    help|-h|--help) cmd_help ;;
    *)              echo "Unknown command: $noun"; echo "Run 'jt help' for usage."; exit 1 ;;
esac
