#!/usr/bin/env bash
set -euo pipefail

# jt — Jolteon worktree & service manager
# See: jt help

REPO="$HOME/Work/jolteon"
WORKSPACE="$HOME/Work/workspaces/jolteon"

# Prefer system-installed Python (e.g. Homebrew) over uv-managed downloads
export UV_PYTHON_PREFERENCE=system

# ─── Helpers ───────────────────────────────────────────────

hint_worktree() {
    echo ""
    echo "Hint: make sure you're in a Jolteon worktree (see 'jt list')."
}

trap 'hint_worktree' ERR

setup_worktree() {
    local target_dir="$1"

    echo "Copying environment files..."
    (cd "$REPO" && find . \( -name node_modules -o -name .venv -o -name .git -o -name .data \) -prune -o -name '.env' -print) | while read -r envfile; do
        if [ -f "$REPO/$envfile" ]; then
            mkdir -p "$target_dir/$(dirname "$envfile")"
            cp "$REPO/$envfile" "$target_dir/$envfile"
        fi
    done

    if [ -f "$REPO/CLAUDE.md" ]; then
        cp "$REPO/CLAUDE.md" "$target_dir/CLAUDE.md"
        echo "  copied CLAUDE.md"
    fi

    local d
    for d in .claude .cursor .vscode; do
        if [ -d "$REPO/$d" ] && [ ! -d "$target_dir/$d" ]; then
            cp -r "$REPO/$d" "$target_dir/$d"
            echo "  copied $d/"
        fi
    done

    echo "Installing Python dependencies..."
    (cd "$target_dir" && uv sync --quiet)

    echo "Installing frontend dependencies..."
    (cd "$target_dir/services/frontend" && npm i --silent 2>/dev/null)

    echo "Installing pre-commit hooks..."
    (cd "$target_dir" && uv run pre-commit install)
}

# ─── Commands ──────────────────────────────────────────────

cmd_new() {
    local branch="$1"
    local worktree_dir="$WORKSPACE/$branch"

    if [ -d "$worktree_dir" ]; then
        echo "Error: directory already exists: $worktree_dir"
        echo "Use 'jt open $branch' to cd into it, or 'jt edit $branch' to open in Zed."
        exit 1
    fi

    echo "Creating worktree: $branch"
    git -C "$REPO" fetch origin main --quiet
    mkdir -p "$(dirname "$worktree_dir")"
    git -C "$REPO" worktree add -b "$branch" "$worktree_dir" origin/main
    git -C "$worktree_dir" push -u origin "$branch" --quiet

    setup_worktree "$worktree_dir"

    echo ""
    echo "Done. Worktree ready at:"
    echo "  $worktree_dir"
    echo ""
    echo "To start working:"
    echo "  cd $worktree_dir"
    echo "  jt serve"
}

cmd_checkout() {
    local branch="$1"
    local worktree_dir="$WORKSPACE/$branch"

    if [ -d "$worktree_dir" ]; then
        echo "Error: directory already exists: $worktree_dir"
        echo "Use 'jt open $branch' to cd into it, or 'jt edit $branch' to open in Zed."
        exit 1
    fi

    echo "Fetching remote branch: $branch"
    git -C "$REPO" fetch origin "$branch" --quiet

    if ! git -C "$REPO" rev-parse "origin/$branch" >/dev/null 2>&1; then
        echo "Error: remote branch 'origin/$branch' not found."
        echo "Use 'jt new $branch' to create a new branch instead."
        exit 1
    fi

    echo "Creating worktree: $branch"
    mkdir -p "$(dirname "$worktree_dir")"
    git -C "$REPO" worktree add "$worktree_dir" "origin/$branch"
    git -C "$worktree_dir" checkout -b "$branch" 2>/dev/null || true

    setup_worktree "$worktree_dir"

    echo ""
    echo "Done. Worktree ready at:"
    echo "  $worktree_dir"
    echo ""
    echo "To start working:"
    echo "  cd $worktree_dir"
    echo "  jt serve"
}

cmd_open() {
    local branch="$1"
    local worktree_dir="$WORKSPACE/$branch"

    if [ ! -d "$worktree_dir" ]; then
        echo "Error: no worktree at $worktree_dir"
        echo "Use 'jt list' to see available worktrees, or 'jt new $branch' to create one."
        exit 1
    fi

    cd "$worktree_dir"
    exec "$SHELL"
}

cmd_list() {
    printf "%-40s %s\n" "BRANCH" "PATH"
    printf '─%.0s' $(seq 1 80)
    echo
    git -C "$REPO" worktree list --porcelain 2>/dev/null \
    | awk '/^worktree / { dir=$2 } /^branch / {
        branch=$2; sub("refs/heads/", "", branch);
        printf "%-40s %s\n", branch, dir
    }'
}

cmd_remove() {
    local branch="$1"
    local worktree_dir="$WORKSPACE/$branch"

    if [ ! -d "$worktree_dir" ]; then
        echo "No worktree at $worktree_dir"
        exit 1
    fi

    read -rp "Remove worktree at $worktree_dir? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        git -C "$REPO" worktree remove "$worktree_dir"
        git -C "$REPO" branch -d "$branch" 2>/dev/null && echo "Deleted branch: $branch" || true
        echo "Removed worktree: $worktree_dir"
    fi
}

cmd_setup() {
    local dir="${1:-$(pwd)}"

    if [ ! -d "$dir" ]; then
        # Try as a branch name
        if [ -d "$WORKSPACE/$dir" ]; then
            dir="$WORKSPACE/$dir"
        else
            echo "Error: no directory at $dir"
            exit 1
        fi
    fi

    setup_worktree "$dir"
    echo ""
    echo "Done. Worktree ready at:"
    echo "  $dir"
}

cmd_edit() {
    local branch="${1:-}"
    local dir

    if [ -z "$branch" ]; then
        dir="$(pwd)"
    else
        dir="$WORKSPACE/$branch"
    fi

    if [ ! -d "$dir" ]; then
        echo "Error: no directory at $dir"
        exit 1
    fi

    local zed_cmd
    zed_cmd="$(command -v zed 2>/dev/null || command -v zeditor 2>/dev/null)" || { echo "Error: zed/zeditor not found"; exit 1; }
    "$zed_cmd" "$dir"
}

cmd_serve() {

    local env="${1:-}"

    if [ -z "$env" ]; then
        echo "Select environment:"
        echo "  1) lcl"
        echo "  2) dev"
        echo "  3) prd"
        read -rp "Environment [1]: " choice
        case "${choice:-1}" in
            1|lcl) env="lcl" ;;
            2|dev) env="dev" ;;
            3|prd) env="prd" ;;
            *)     echo "Invalid choice"; exit 1 ;;
        esac
    fi

    # Stop any running services first
    cmd_stop 2>/dev/null || true

    local env_file="$HOME/.config/jt/environments.sh"
    if [ ! -f "$env_file" ]; then
        echo "Error: missing $env_file"
        echo ""
        echo "Create it with env_lcl(), env_dev(), env_prd() shell functions."
        echo "See: jt help serve"
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$env_file"

    case "$env" in
        lcl) env_lcl ;;
        dev) env_dev ;;
        prd) env_prd ;;
        *)
            echo "Unknown environment: $env"
            echo "Valid options: lcl, dev, prd"
            exit 1
            ;;
    esac

    echo ""
    echo "Starting services..."
    echo "  Backend:  http://localhost:8000"
    echo "  Frontend: http://localhost:5173"
    echo ""

    trap 'echo ""; echo "Stopping services..."; kill 0' INT TERM

    (cd services/dashboard-api 2>/dev/null || cd "$REPO/services/dashboard-api"
     uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload) &

    local vite_env=""
    if [ "${DISABLE_AUTH_RAW:-}" = "true" ]; then
        vite_env="VITE_DISABLE_AUTH=true"
    fi
    (cd services/frontend 2>/dev/null || cd "$REPO/services/frontend"
     env $vite_env npm run dev) &

    echo "Services started. Press Ctrl+C to stop."
    echo ""
    wait
}

cmd_generate() {


    local javm_bin
    javm_bin="$(command -v javm 2>/dev/null || echo "$HOME/.local/bin/javm")"
    if [ ! -x "$javm_bin" ]; then
        echo "Error: javm is not installed."
        echo ""
        echo "javm is required to manage Java versions for the OpenAPI generator."
        echo "Install it first, then re-run 'jt generate'."
        exit 1
    fi

    if ! curl -sf http://localhost:8000/docs >/dev/null 2>&1; then
        echo "Dashboard API is not running on localhost:8000."
        read -rp "Start it with 'jt serve'? [Y/n] " confirm
        if [[ "${confirm:-y}" =~ ^[Nn]$ ]]; then
            echo "Aborted. Start the API first, then re-run 'jt generate'."
            exit 1
        fi
        cmd_serve
        # serve blocks (wait), so we won't reach here
    fi

    local sdk_dir
    sdk_dir="$(cd packages/dashboard-api-ts-sdk 2>/dev/null && pwd)" || sdk_dir="$REPO/packages/dashboard-api-ts-sdk"

    # javm modifies JAVA_HOME/PATH via a shell function (fd3 protocol) that is
    # only available in interactive zsh. Replicate the protocol directly so the
    # env vars are exported for npm run build.
    local fd3
    fd3=$(mktemp)
    "$javm_bin" --fd3 "$fd3" use 25
    if [ -s "$fd3" ]; then
        while IFS=$'\t' read -r op key val; do
            [ "$op" = "SET" ] && export "$key=$val"
            [ "$op" = "UNSET" ] && unset "$key"
        done < "$fd3"
    fi
    rm -f "$fd3"

    echo "Generating SDK..."
    (cd "$sdk_dir" && npm run build)
    echo "Done."
}

cmd_mcp() {

    local env="${1:-}"
    local port="${2:-8002}"

    if [ -z "$env" ]; then
        echo "Select environment:"
        echo "  1) lcl  — local dashboard-api on localhost:8000"
        echo "  2) dev  — https://dashboard-api.dev.companion.energy"
        echo "  3) prd  — https://dashboard-api.prd.companion.energy"
        read -rp "Environment [2]: " choice
        case "${choice:-2}" in
            1|lcl) env="lcl" ;;
            2|dev) env="dev" ;;
            3|prd) env="prd" ;;
            *)     echo "Invalid choice"; exit 1 ;;
        esac
    fi

    local mcp_dir
    mcp_dir="$(cd services/mcp-service 2>/dev/null && pwd)" || mcp_dir="$REPO/services/mcp-service"
    local spec_file="$mcp_dir/app/openapi_spec.json"

    # Generate OpenAPI spec if missing
    if [ ! -f "$spec_file" ]; then
        echo "OpenAPI spec not found, generating..."
        local api_dir
        api_dir="$(cd services/dashboard-api 2>/dev/null && pwd)" || api_dir="$REPO/services/dashboard-api"

        # Source env config for DB creds (needed by dashboard-api import)
        local env_file="$HOME/.config/jt/environments.sh"
        if [ -f "$env_file" ]; then
            # shellcheck source=/dev/null
            source "$env_file"
            env_dev  # dev creds are fine for spec generation
        fi

        (cd "$api_dir" && \
            GOOGLE_GEOCODING_API_KEY="${GOOGLE_GEOCODING_API_KEY:-x}" \
            WORKOS_CLIENT_ID="${WORKOS_CLIENT_ID:-x}" \
            WORKOS_CLIENT_SECRET="${WORKOS_CLIENT_SECRET:-x}" \
            FLUVIUS_CLIENT_SECRET="${FLUVIUS_CLIENT_SECRET:-x}" \
            FLUVIUS_SUBSCRIPTION_KEY="${FLUVIUS_SUBSCRIPTION_KEY:-x}" \
            DAGSTER_URL="${DAGSTER_URL:-http://x}" \
            PYTHONPATH=. uv run python ../mcp-service/scripts/generate_openapi_spec.py)
    fi

    # Stop any existing MCP server
    local mcp_pids
    mcp_pids=$(lsof -ti :"$port" 2>/dev/null || true)
    if [ -n "$mcp_pids" ]; then
        echo "$mcp_pids" | xargs kill -9 2>/dev/null || true
        sleep 1
    fi

    # Set environment-specific config
    local dashboard_url disable_auth
    case "$env" in
        lcl)
            dashboard_url="http://localhost:8000"
            disable_auth="true"
            ;;
        dev)
            dashboard_url="https://dashboard-api.dev.companion.energy"
            disable_auth="false"
            ;;
        prd)
            dashboard_url="https://dashboard-api.prd.companion.energy"
            disable_auth="false"
            ;;
    esac

    # Source dashboard-api .env for WorkOS creds
    local dashboard_env
    dashboard_env="$(cd services/dashboard-api 2>/dev/null && pwd)/.env" || dashboard_env="$REPO/services/dashboard-api/.env"
    if [ -f "$dashboard_env" ]; then
        set -a
        # shellcheck source=/dev/null
        source "$dashboard_env"
        set +a
    fi

    echo ""
    echo "Starting MCP service..."
    echo "  Environment:    $env"
    echo "  Dashboard API:  $dashboard_url"
    echo "  Auth:           $([ "$disable_auth" = "true" ] && echo "disabled" || echo "OAuth (WorkOS)")"
    echo "  MCP endpoint:   http://localhost:$port/mcp/"
    echo ""

    trap 'echo ""; echo "Stopping MCP service..."; kill 0' INT TERM

    (cd "$mcp_dir" && \
        DASHBOARD_API_BASE_URL="$dashboard_url" \
        DISABLE_AUTH="$disable_auth" \
        MCP_BASE_URL="http://localhost:$port" \
        COMPANION_ENV="local" \
        LOG_LEVEL="INFO" \
        uv run uvicorn app.main:app --port "$port") &

    wait
}

cmd_stop() {
    local killed=0

    local pids
    pids=$(lsof -ti :8000 2>/dev/null || true)
    if [ -n "$pids" ]; then
        echo "$pids" | xargs kill -9 2>/dev/null || true
        echo "Stopped backend (port 8000)"
        killed=1
    fi

    pids=$(lsof -ti :5173 2>/dev/null || true)
    if [ -n "$pids" ]; then
        echo "$pids" | xargs kill -9 2>/dev/null || true
        echo "Stopped frontend (port 5173)"
        killed=1
    fi

    if [ "$killed" -eq 0 ]; then
        echo "No services running."
    fi
}

cmd_browse() {
    local profile="${1:-}"
    local url="${2:-http://localhost:5173}"
    local profiles_dir="$HOME/Work/browser-profiles"

    if [ "$profile" = "stop" ]; then
        if pkill -f 'agent-browser' 2>/dev/null; then
            echo "Stopped agent-browser"
        else
            echo "No agent-browser running."
        fi
        return
    fi

    if [ -z "$profile" ]; then
        echo "Usage: jt browse <profile> [url]"
        echo ""
        echo "Profiles:"
        for p in "$profiles_dir"/*/; do
            echo "  $(basename "$p")"
        done
        exit 1
    fi

    if [ ! -d "$profiles_dir/$profile" ]; then
        echo "Error: unknown profile '$profile'"
        echo "Available profiles:"
        for p in "$profiles_dir"/*/; do
            echo "  $(basename "$p")"
        done
        exit 1
    fi

    agent-browser close 2>/dev/null || true
    echo "Opening browser: $url (profile: $profile)"
    agent-browser --profile "$profiles_dir/$profile" --headed open "$url"
}

cmd_help() {
    cat <<'HELP'
jt — Jolteon worktree & service manager

Usage:
  jt <command> [arguments]

Worktree commands:
  jt new <branch>              Create a new worktree and branch
  jt checkout <branch>         Create a worktree from an existing remote branch
  jt setup [branch|path]       Copy env files + install deps (default: cwd)
  jt open <branch>             Open a shell in an existing worktree
  jt edit [branch]             Open worktree in Zed (default: current dir)
  jt list                      List all worktrees
  jt remove <branch>           Remove a worktree and its branch

Service commands:
  jt serve [lcl|dev|prd]       Start backend + frontend (default: lcl)
  jt mcp [lcl|dev|prd] [port]  Start MCP service (default: dev, port 8002)
  jt stop                      Stop all services

Browser commands:
  jt browse <profile> [url]    Open headed browser (default: localhost:5173)
  jt browse stop               Stop agent-browser

SDK commands:
  jt generate                   Generate the dashboard API TypeScript SDK

Other:
  jt help                      Show this help

Examples:
  jt new feat/battery-charts
  jt checkout feat/partner-portal-v1
  jt open feat/battery-charts
  jt edit feat/battery-charts
  jt serve prd
  jt mcp dev
  jt mcp prd 9000
  jt browse customer
  jt browse root http://localhost:5173/admin
  jt remove feat/battery-charts
HELP
}

# ─── Main ──────────────────────────────────────────────────

case "${1:-help}" in
    new)    shift; cmd_new "$1" ;;
    checkout|co) shift; cmd_checkout "$1" ;;
    setup)  shift; cmd_setup "${1:-}" ;;
    open)   shift; cmd_open "$1" ;;
    edit)   shift; cmd_edit "${1:-}" ;;
    list|ls) cmd_list ;;
    remove|rm) shift; cmd_remove "$1" ;;
    serve)  shift; cmd_serve "${1:-}" ;;
    mcp)    shift; cmd_mcp "${1:-}" "${2:-8002}" ;;
    stop)   cmd_stop ;;
    browse) shift; cmd_browse "${1:-}" "${2:-}" ;;
    generate|gen) cmd_generate ;;
    help|-h|--help) cmd_help ;;
    *)      echo "Unknown command: $1"; echo "Run 'jt help' for usage."; exit 1 ;;
esac
