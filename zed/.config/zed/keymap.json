[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-\\": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-b": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-|": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-r": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-|": "editor::MoveToEnclosingBracket"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-\\": "pane::SplitRight"
    }
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "cmd-k": "assistant::InlineAssist"
    }
  },
  {
    "context": "Terminal",
    "unbind": {
      "cmd-k": "assistant::InlineAssist"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "alt-cmd-k": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "alt-cmd-t": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-cmd-k": "agent::ToggleThinkingMode"
    }
  }
]